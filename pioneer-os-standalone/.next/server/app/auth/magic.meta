{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/magic/layout,_N_T_/auth/magic/page,_N_T_/auth/magic"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auth/magic/__PAGE__",
    "/auth/magic",
    "/auth",
    "/_index",
    "/_head"
  ]
}