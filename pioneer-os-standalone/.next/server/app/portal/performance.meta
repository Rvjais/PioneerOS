{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/portal/layout,_N_T_/portal/performance/layout,_N_T_/portal/performance/page,_N_T_/portal/performance"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/portal/performance/__PAGE__",
    "/portal/performance",
    "/portal",
    "/_index",
    "/_head"
  ]
}