{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/embed/layout,_N_T_/embed/support/layout,_N_T_/embed/support/page,_N_T_/embed/support"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/embed/support/__PAGE__",
    "/embed/support",
    "/embed",
    "/_index",
    "/_head"
  ]
}