{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/embed/layout,_N_T_/embed/welcome/layout,_N_T_/embed/welcome/page,_N_T_/embed/welcome"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/embed/welcome/__PAGE__",
    "/embed/welcome",
    "/embed",
    "/_index",
    "/_head"
  ]
}