  meetingCompliance                                     MeetingCompliance[]
  meetings                                              MeetingParticipant[]
  monthlyGrowthScores                                   MonthlyGrowthScore[]
  notifications                                         Notification[]
  pipManagedPlans                                       PIPPlan[]                    @relation("PIPManager")
  pipPlans                                              PIPPlan[]                    @relation("PIPEmployee")
  pageFeedback                                          PageFeedback[]
  scores                                                PerformanceScore[]
  posts                                                 Post[]
  profile                                               Profile?
  quotesCreated                                         Quote[]                      @relation("QuoteCreator")
  rbcAccruals                                           RBCAccrual[]
  rbcPayouts                                            RBCPayout[]
  rbcPot                                                RBC_Pot?
  givenRecognition                                      Recognition[]                @relation("RecognitionGiver")
  recognition                                           Recognition[]                @relation("RecognitionReceiver")
  expensesCreated                                       RecurringExpense[]           @relation("ExpenseCreator")
  referralsReceived                                     ReferralBonus[]              @relation("ReferredUser")
  referralsMade                                         ReferralBonus[]              @relation("Referrer")
  salesDailyTasks                                       SalesDailyTask[]             @relation("SalesDailyTaskUser")
  salesDeals                                            SalesDeal[]                  @relation("SalesDealUser")
  accountsHandovers                                     SalesHandover[]              @relation("SalesHandoverAccounts")
  salesHandovers                                        SalesHandover[]              @relation("SalesHandoverSales")
  salesMeetings                                         SalesMeeting[]               @relation("SalesMeetingUser")
  salesWhatsAppMessages                                 SalesWhatsAppMessage[]       @relation("SalesWhatsAppUser")
  seoBacklinksCreated                                   SeoBacklink[]                @relation("BacklinkCreator")
  seoContentWritten                                     SeoContent[]                 @relation("ContentWriter")
  seoTasksAssigned                                      SeoTask[]                    @relation("SeoTaskAssignee")
  seoTasksReviewing                                     SeoTask[]                    @relation("SeoTaskReviewer")
  sharedWhatsAppChats                                   SharedWhatsAppChat[]
  socialMediaPageMetrics                                SocialMediaPageMetrics[]
  socialMediaPosts                                      SocialMediaPost[]
  supportTickets                                        SupportTicket[]              @relation("SupportTicketAssignee")
  tacticalGoals                                         TacticalGoal[]
  tacticalMeetings                                      TacticalMeeting[]
  assignedTasks                                         Task[]                       @relation("TaskAssignee")
  createdTasks                                          Task[]                       @relation("TaskCreator")
  reviewedTasks                                         Task[]                       @relation("TaskReviewer")
  taskComments                                          TaskComment[]
  ticketActivities                                      TicketActivity[]             @relation("TicketActivityUser")
  timeEntries                                           TimeEntry[]
  buddy                                                 User?                        @relation("BuddySystem", fields: [buddyId], references: [id])
  buddies                                               User[]                       @relation("BuddySystem")
  certifications                                        UserCertification[]
  customRoles                                           UserCustomRole[]
  googleDrive                                           UserGoogleDrive?
  trainings                                             UserTraining[]
  requestedTestimonials                                 VideoTestimonial[]           @relation("TestimonialRequester")
  verifiedTestimonials                                  VideoTestimonial[]           @relation("TestimonialVerifier")
  violations                                            Violations[]
  WebBugReport_WebBugReport_assignedToIdToUser          WebBugReport[]               @relation("WebBugReport_assignedToIdToUser")
  WebBugReport_WebBugReport_resolvedByIdToUser          WebBugReport[]               @relation("WebBugReport_resolvedByIdToUser")
  WebChangeRequest_WebChangeRequest_assignedToIdToUser  WebChangeRequest[]           @relation("WebChangeRequest_assignedToIdToUser")
  WebChangeRequest_WebChangeRequest_completedByIdToUser WebChangeRequest[]           @relation("WebChangeRequest_completedByIdToUser")
  assignedWebPhases                                     WebProjectPhase[]
  whatsAppAccess                                        WhatsAppAccess[]
  whatsAppChatNotes                                     WhatsAppChatNote[]
  workAnniversaries                                     WorkAnniversaryReminder[]
  workDeliverables                                      WorkDeliverable[]
  workEntries                                           WorkEntry[]
  loginSessions                                         LoginSession[]

  @@index([role])
  @@index([department])
  @@index([status])
  @@index([joiningDate])
}

model Profile {
  id                            String    @id @default(cuid())
  userId                        String    @unique
  ndaSigned                     Boolean   @default(false) @map("nda_signed")
  ndaSignedAt                   DateTime? @map("nda_signed_at")
  biometricPunch                Boolean   @default(false)
  razorpayLinked                Boolean   @default(false)
  profilePicture                String?
  panCard                       String?
  aadhaar                       String?
  linkedIn                      String?
  favoriteFood                  String?
  parentsPhone1                 String?
  parentsPhone2                 String?
  livingSituation               String?
  distanceFromOffice            String?
  skills                        String?
  bio                           String?
  emergencyContactName          String?
  emergencyContactPhone         String?
  panCardUrl                    String?
  aadhaarUrl                    String?
  bankDetailsUrl                String?
  educationCertUrl              String?
  employeeHandbookAccepted      Boolean   @default(false)
  socialMediaPolicyAccepted     Boolean   @default(false)
  clientConfidentialityAccepted Boolean   @default(false)
  allPoliciesAccepted           Boolean   @default(false)
  policiesAcceptedAt            DateTime?
  completionPercentage          Int       @default(0)
  signatureData                 String?
  signatureType                 String?
  signedAt                      DateTime?
  selfieImage                   String?
  kycVerifiedAt                 DateTime?
  allocatedDeviceType           String?
  allocatedDeviceId             String?
  personalMobileNumber          String?
  officialPhoneNumber           String?
  hasWhatsAppAccess             Boolean   @default(false)
  deviceAllocatedAt             DateTime?
  user                          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VideoTestimonial {
  id                 String    @id @default(cuid())
  requestedById      String
  clientId           String
  requestedAt        DateTime  @default(now())
  requestMessage     String?
  clientContactName  String?
  clientContactEmail String?
  youtubeUrl         String?
  thumbnailUrl       String?
  title              String?
  description        String?
  duration           Int?
  status             String    @default("REQUESTED")
  receivedAt         DateTime?
  verifiedAt         DateTime?
  verifiedById       String?
  verificationNotes  String?
  voucherAmount      Float     @default(1000)
  voucherCode        String?
  rewardedAt         DateTime?
  badgeColor         String    @default("gold")
  isFeatured         Boolean   @default(false)
  displayOrder       Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  client             Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requestedBy        User      @relation("TestimonialRequester", fields: [requestedById], references: [id])
  verifiedBy         User?     @relation("TestimonialVerifier", fields: [verifiedById], references: [id])

  @@index([requestedById])
  @@index([clientId])
  @@index([status])
  @@index([verifiedById])
}

