generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DistributedLock {
  id         String   @id
  lockName   String   @unique
  acquiredAt DateTime @default(now())
  expiresAt  DateTime

  @@index([lockName])
  @@index([expiresAt])
}

model User {
  id                                                    String                       @id @default(cuid())
  empId                                                 String                       @unique
  firstName                                             String
  lastName                                              String?
  phone                                                 String                       @unique
  email                                                 String?                      @unique
  password                                              String?
  twoFactorEnabled                                      Boolean                      @default(false)
  twoFactorSecret                                       String?
  twoFactorBackupCodes                                  String?
  twoFactorVerifiedAt                                   DateTime?
  role                                                  String
  department                                            String
  employeeType                                          String                       @default("FULL_TIME")
  joiningDate                                           DateTime
  dateOfBirth                                           DateTime?
  status                                                String                       @default("ACTIVE")
  bloodGroup                                            String?
  address                                               String?
  /// Comma-separated string of languages spoken, e.g. "English,Hindi,Marathi"
  languages                                             String?
  /// Comma-separated string of AI tools used, e.g. "ChatGPT,Midjourney,Copilot"
  aiTools                                               String?
  education                                             String?
  healthConditions                                      String?
  capacity                                              Int                          @default(50)
  buddyId                                               String?
  profileCompletionStatus                               String                       @default("INCOMPLETE")
  onboardingStep                                        Int                          @default(0)
  hrVerifiedBy                                          String?
  hrVerifiedAt                                          DateTime?
  appraisalDate                                         DateTime?
  clientCapacity                                        Int                          @default(10)
  deletedAt                                             DateTime?
  createdAt                                             DateTime                     @default(now())
  updatedAt                                             DateTime                     @updatedAt
  aiExtractions                                         AIExtractionSession[]
  accountability                                        AccountabilityCharter[]
  accountabilityScores                                  AccountabilityScore[]
  achievements                                          Achievement[]
  arcadeTransactions                                    ArcadePointTransaction[]
  arcadeRedemptions                                     ArcadeRedemption[]
  assetAssignments                                      AssetAssignment[]
  attendance                                            Attendance[]
  attendanceImports                                     AttendanceImport[]
  budgetAlerts                                          BudgetAlert[]
