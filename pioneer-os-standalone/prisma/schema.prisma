  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  client       Client           @relation("SeoKeywords", fields: [clientId], references: [id], onDelete: Cascade)
  rankHistory  SeoRankHistory[]

  @@index([clientId])
  @@index([clientId, keyword])
}

model SeoRankHistory {
  id        String     @id @default(cuid())
  keywordId String
  rank      Int
  date      DateTime   @default(now())
  keyword   SeoKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@index([keywordId])
  @@index([keywordId, date])
}

model SeoBacklink {
  id              String   @id @default(cuid())
  clientId        String
  targetUrl       String
  anchorText      String
  backlinkSource  String
  domainAuthority Int      @default(0)
  status          String   @default("SUBMITTED")
  liveUrl         String?
  submittedDate   DateTime @default(now())
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  client          Client   @relation("SeoBacklinks", fields: [clientId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("BacklinkCreator", fields: [createdById], references: [id])

  @@index([clientId])
  @@index([status])
}

model SeoContent {
  id            String    @id @default(cuid())
  clientId      String
  blogTopic     String
  targetKeyword String?
  writerId      String?
  status        String    @default("DRAFT")
  wordCount     Int       @default(0)
  publishedUrl  String?
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  client        Client    @relation("SeoContent", fields: [clientId], references: [id], onDelete: Cascade)
  writer        User?     @relation("ContentWriter", fields: [writerId], references: [id])

  @@index([clientId])
  @@index([writerId])
  @@index([status])
}

model GbpProfile {
  id           String      @id @default(cuid())
  clientId     String
  profileName  String
  location     String
  category     String      @default("Business")
  totalReviews Int         @default(0)
  rating       Float       @default(0)
  status       String      @default("ACTIVE")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  metrics      GbpMetric[]
  posts        GbpPost[]
  client       Client      @relation("GbpProfiles", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model GbpPost {
  id          String     @id @default(cuid())
  profileId   String
  postType    String     @default("UPDATE")
  content     String
  proofLink   String?
  views       Int        @default(0)
  publishedAt DateTime   @default(now())
  createdAt   DateTime   @default(now())
  profile     GbpProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model GbpMetric {
  id            String     @id @default(cuid())
  profileId     String
  month         String
  calls         Int        @default(0)
  directions    Int        @default(0)
  profileViews  Int        @default(0)
  websiteClicks Int        @default(0)
  monthlyPosts  Int        @default(0)
  createdAt     DateTime   @default(now())
  profile       GbpProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, month])
  @@index([profileId])
}

model SeoTask {
  id           String    @id @default(cuid())
  clientId     String
  taskType     String
  category     String?
  description  String
  assignedToId String?
  reviewerId   String?
  priority     String    @default("MEDIUM")
  status       String    @default("TODO")
  deadline     DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedTo   User?     @relation("SeoTaskAssignee", fields: [assignedToId], references: [id])
  client       Client    @relation("SeoTasks", fields: [clientId], references: [id], onDelete: Cascade)
  reviewer     User?     @relation("SeoTaskReviewer", fields: [reviewerId], references: [id])

  @@index([clientId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
}

model Campaign {
  id               String            @id @default(cuid())
  clientId         String
  name             String
  platform         String
  campaignType     String?
  objective        String?
  status           String            @default("DRAFT")
  externalId       String?
  dailyBudget      Float?
  monthlyBudget    Float?
  totalBudget      Float?
  currency         String            @default("INR")
  targetAudience   String?
  keywords         String?
  placements       String?
  impressions      Int               @default(0)
  clicks           Int               @default(0)
  conversions      Int               @default(0)
  leads            Int               @default(0)
  spend            Float             @default(0)
  cpc              Float?
  cpl              Float?
  ctr              Float?
  roas             Float?
  qualityScore     Float?
  startDate        DateTime?
  endDate          DateTime?
  assignedToId     String?
  createdById      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  abTests          ABTest[]
  adCreatives      AdCreative[]
  adSpendRecords   AdSpend[]
  assignedTo       User?             @relation("CampaignAssignee", fields: [assignedToId], references: [id])
  client           Client            @relation("ClientCampaigns", fields: [clientId], references: [id], onDelete: Cascade)
  conversionEvents ConversionEvent[]

  @@index([clientId])
  @@index([platform])
  @@index([status])
  @@index([assignedToId])
  @@index([clientId, platform, status])
}

model AdCreative {
  id              String    @id @default(cuid())
  campaignId      String
  clientId        String
  name            String
  type            String
  platform        String
  status          String    @default("DRAFT")
  headline        String?
  description     String?
  callToAction    String?
  mediaUrl        String?
  thumbnailUrl    String?
  landingPageUrl  String?
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  conversions     Int       @default(0)
  ctr             Float?
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  version         Int       @default(1)
  parentId        String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([clientId])
  @@index([status])
}

model AdSpend {
  id          String   @id @default(cuid())
  campaignId  String
  clientId    String
  date        DateTime
  platform    String
  amount      Float
  currency    String   @default("INR")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  leads       Int      @default(0)
  cpc         Float?
  cpl         Float?
  ctr         Float?
  roas        Float?
  createdAt   DateTime @default(now())
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([clientId])
  @@index([date])
  @@index([clientId, date])
  @@index([platform, date])
}

model BudgetAllocation {
  id              String    @id @default(cuid())
  clientId        String
  month           DateTime
  platform        String
  allocatedAmount Float
  spentAmount     Float     @default(0)
  currency        String    @default("INR")
  dailyTarget     Float?
  pacingStatus    String    @default("ON_TRACK")
  approvedById    String?
  approvedAt      DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  client          Client    @relation("ClientBudgets", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, month, platform])
  @@index([clientId])
  @@index([month])
}

model ABTest {
  id              String    @id @default(cuid())
  campaignId      String
  clientId        String
  name            String
  hypothesis      String?
  status          String    @default("RUNNING")
  testType        String
  variantA        String
  variantB        String
  winner          String?
  confidenceLevel Float?
  startDate       DateTime  @default(now())
  endDate         DateTime?
  conclusion      String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([clientId])
  @@index([status])
}

model ConversionEvent {
  id         String    @id @default(cuid())
  campaignId String?
  clientId   String
  eventName  String
  platform   String
  source     String?
  leadName   String?
  leadEmail  String?
  leadPhone  String?
  adSpend    Float?
  revenue    Float?
  occurredAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  @@index([clientId])
  @@index([campaignId])
  @@index([platform])
  @@index([occurredAt])
  @@index([clientId, occurredAt])
}
