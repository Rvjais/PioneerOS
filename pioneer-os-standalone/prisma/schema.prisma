model ClientTeamMember {
  id         String   @id @default(cuid())
  clientId   String
  userId     String
  role       String
  isPrimary  Boolean  @default(false)
  assignedAt DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([clientId])
  @@index([userId])
  @@index([role])
}

model ClientScope {
  id        String   @id @default(cuid())
  clientId  String
  category  String
  item      String
  quantity  Int
  delivered Int      @default(0)
  month     DateTime
  status    String   @default("ON_TRACK")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, category])
  @@index([clientId, month])
  @@index([status])
}

model ClientDeliverable {
  id            String    @id @default(cuid())
  clientId      String
  category      String
  workItem      String
  description   String?
  month         String
  proofUrl      String?
  kpi           String?
  status        String    @default("PENDING")
  submittedAt   DateTime?
  submittedById String?
  reviewedAt    DateTime?
  reviewedById  String?
  reviewNotes   String?
  clientVisible Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy     User?     @relation("DeliverableCreator", fields: [createdById], references: [id])
  reviewedBy    User?     @relation("DeliverableReviewer", fields: [reviewedById], references: [id])
  submittedBy   User?     @relation("DeliverableSubmitter", fields: [submittedById], references: [id])

  @@index([clientId])
  @@index([clientId, month])
  @@index([category])
  @@index([status])
  @@index([submittedById])
}

model Task {
  id              String        @id @default(cuid())
  title           String
  description     String?
  department      String
  priority        String        @default("MEDIUM")
  status          String        @default("TODO")
  type            String        @default("TASK")
  dueDate         DateTime?
  startDate       DateTime?
  completedAt     DateTime?
  assigneeId      String?
  creatorId       String
  reviewerId      String?
  clientId        String?
  qaStatus        String?
  qaComments      String?
  qaReviewedAt    DateTime?
  isRecurring     Boolean       @default(false)
  recurrence      String?
  parentTaskId    String?
  attachments     String?
  estimatedHours  Float?
  actualHours     Float?
  timeSpent       Int           @default(0)
  timerStartedAt  DateTime?
  taskOutcome     String        @default("PENDING")
  breakdownReason String?
  proofUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subtasks        Subtask[]
  assignee        User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  creator         User          @relation("TaskCreator", fields: [creatorId], references: [id])
  reviewer        User?         @relation("TaskReviewer", fields: [reviewerId], references: [id])
  comments        TaskComment[]
  timeEntries     TimeEntry[]

  @@index([assigneeId])
  @@index([creatorId])
  @@index([clientId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([department])
  @@index([assigneeId, status])
  @@index([clientId, status])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  type      String   @default("COMMENT")
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Subtask {
  id          String    @id @default(cuid())
  taskId      String
  title       String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  completedBy String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  hours       Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  priority  String   @default("NORMAL")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model Meeting {
  id                 String               @id @default(cuid())
  title              String
  description        String?
  type               String
  category           String               @default("GENERAL")
  date               DateTime
  duration           Int?
  location           String?
