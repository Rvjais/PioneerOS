  name                      String
  logoUrl                   String?
  contactName               String?
  contactEmail              String?
  contactPhone              String?
  whatsapp                  String?
  websiteUrl                String?
  address                   String?
  gstNumber                 String?
  panNumber                 String?
  state                     String?
  city                      String?
  pincode                   String?
  businessType              String?
  industry                  String?
  monthlyBudget             String?
  monthlyFee                Float?
  tier                      String                     @default("STANDARD")
  clientSegment             String                     @default("INDIAN")
  status                    String                     @default("ACTIVE")
  clientType                String                     @default("RECURRING")
  isWebTeamClient           Boolean                    @default(false)
  addedByUserId             String?
  webProjectStatus          String?
  webProjectStartDate       DateTime?
