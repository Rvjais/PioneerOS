  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // For which client (optional - some work is internal)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // When - for efficient date-based queries
  date  DateTime // Work date
  year  Int // Extracted for partitioning
  month Int // Extracted for monthly aggregation (1-12)
  week  Int // ISO week number for weekly views

  // What category of work
  category String // SEO, SOCIAL, ADS, WEB, DESIGN, VIDEO, ACCOUNTS, HR, SALES, OPERATIONS

  // Specific deliverable type within category
  deliverableType String // e.g., CAROUSEL, REEL, BLOG_POST, LANDING_PAGE, CAMPAIGN

  // Quantity and metrics
  quantity Int @default(1)

  // Flexible metrics as JSON (department-specific)
  // SEO: { keywords: 10, backlinks: 5, organicTraffic: 1500 }
  // ADS: { spend: 50000, impressions: 10000, clicks: 500, conversions: 25, roas: 4.2 }
  // SOCIAL: { reach: 5000, engagement: 250, followers: 50 }
  metrics String? // JSON

  // Results/outcomes
  resultSummary String? // Brief description of results achieved
  resultMetrics String? // JSON - quantified results

  // Time tracking
  hoursSpent Float?

  // Description and notes
  description String?
  notes       String?

  // Proof files (stored in Google Drive)
  files WorkEntryFile[]

  // Design/Creative-specific KPIs (for DESIGN, VIDEO, SOCIAL categories)
  qualityScore    Int? // Rating from 1-10 (assigned by reviewer/manager)
  revisionCount   Int     @default(0) // Number of revisions needed
  turnaroundHours Float? // Hours from assignment to first delivery
  deliverableUrl  String? // Direct URL to the deliverable (post URL, design file, etc.)

  // Workflow status
  status        String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED
  submittedAt   DateTime?
  approvedBy    String?
  approvedAt    DateTime?
  rejectionNote String?

  // Meeting references (auto-linked)
  tacticalMeetingId  String? // Link to monthly tactical meeting
  strategicMeetingId String? // Link to quarterly strategic meeting

  // WhatsApp integration
  whatsappChatId String? // Link to WhatsApp chat for tracking

  // Goal alignment
  goalLinks TaskGoalLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for scalability - query by date range, user, client efficiently
  @@index([userId, date])
  @@index([userId, year, month])
  @@index([clientId, year, month])
  @@index([category, year, month])
  @@index([date])
  @@index([year, month])
  @@index([status])
  @@index([whatsappChatId])
  @@index([userId, category, qualityScore]) // For design quality tracking
}

model WorkEntryFile {
  id String @id @default(cuid())

  workEntryId String
  workEntry   WorkEntry @relation(fields: [workEntryId], references: [id], onDelete: Cascade)

  // Google Drive file info
  driveFileId String // Google Drive file ID
  fileName    String
  fileType    String // image/png, application/pdf, etc.
  fileSize    Int // bytes

  // Direct access URL (with expiry)
  webViewLink  String?
  thumbnailUrl String?

  // Categorization
  fileCategory String @default("PROOF") // PROOF, SCREENSHOT, REPORT, CREATIVE, OTHER

  createdAt DateTime @default(now())

  @@index([workEntryId])
  @@index([driveFileId])
}

// ============================================
// DELIVERABLE TYPE CONFIGURATION (Database-driven pricing)
// ============================================

model DeliverableTypeConfig {
  id String @id @default(cuid())

  category    String // SEO, SOCIAL, ADS, WEB, DESIGN, VIDEO
  type        String // CAROUSEL, REEL, BLOG_POST, etc.
  displayName String // Human-readable name

  // Valuation
  unitValue Float // Value in rupees

  // Validation rules
  minQuantity Int @default(1)
  maxQuantity Int @default(100)

  // Required metrics for this type
  requiredMetrics String? // JSON array of required metric keys

  // Active/inactive
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, type])
  @@index([category])
}

// ============================================
// WHATSAPP HUB ENHANCEMENTS
