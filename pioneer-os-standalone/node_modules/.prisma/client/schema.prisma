// ============================================
// CLIENT PROPOSAL & LEDGER SYSTEM
// ============================================

model ClientProposal {
  id    String @id @default(cuid())
  token String @unique @default(cuid())

  // Pre-filled by Accounts/Sales
  prospectName    String
  prospectEmail   String
  prospectPhone   String?
  prospectCompany String?

  // Services & Pricing (JSON fields)
  services      String // JSON: [{serviceId, name, price, isRequired, isSelected}]
  scopeItems    String // JSON: [{category, item, quantity, isModifiable, min, max}]
  basePrice     Float
  gstPercentage Float  @default(18)
  totalPrice    Float

  // Modification rules
  allowServiceModification Boolean @default(true)
  allowScopeModification   Boolean @default(true)

  // Client-submitted data (filled on acceptance)
  clientName       String?
  clientEmail      String?
  clientPhone      String?
  clientCompany    String?
  clientGst        String?
  selectedServices String? // JSON: Final service selections
  selectedScope    String? // JSON: Final scope selections
  finalPrice       Float?

  // ============================================
  // UNIFIED ONBOARDING FIELDS (New)
  // ============================================

  // Step 1: Initial Details
  clientAddress     String?
  clientCity        String?
  clientState       String?
  clientPincode     String?
  contractDuration  String? // 6_MONTHS, 12_MONTHS, 24_MONTHS, ONGOING
  paymentTerms      String? // ADVANCE_100, ADVANCE_50, NET_15, NET_30
  advanceAmount     Float? // Calculated or manual advance
  advancePercentage Int? // 50, 100, etc.

  // Step 2: SLA Agreement
  slaAccepted          Boolean   @default(false)
  slaAcceptedAt        DateTime?
  slaSignerName        String?
  slaSignerDesignation String?
  slaDocumentId        String? // Link to generated SLADocument

  // Step 3: Invoice Generation
  invoiceGenerated   Boolean   @default(false)
  invoiceGeneratedAt DateTime?
  invoiceNumber      String? // PI-YYYY-XXXX

  // Step 4: Payment
  paymentMethod      String? // BANK_TRANSFER, RAZORPAY, CHEQUE, UPI
  paymentConfirmed   Boolean   @default(false)
  paymentConfirmedAt DateTime?
  paymentConfirmedBy String? // User ID (for manual confirmation)
  paymentReference   String? // UTR/Transaction ID
  razorpayOrderId    String?
  razorpayPaymentId  String?

  // Step 5: Account Onboarding
  accountOnboardingCompleted   Boolean   @default(false)
  accountOnboardingCompletedAt DateTime?
  accountOnboardingData        String? // JSON - brand, credentials, working style

  // Step 6: Manager Review
  managerReviewed    Boolean   @default(false)
  managerReviewedAt  DateTime?
  managerReviewedBy  String? // User ID
  accountManagerId   String? // Assigned account manager
  teamAllocated      Boolean   @default(false)
  teamAllocationData String? // JSON: [{userId, role}]
  portalActivated    Boolean   @default(false)
  portalActivatedAt  DateTime?
  kickoffScheduled   Boolean   @default(false)
  kickoffDate        DateTime?

  // Workflow Tracking
  currentStep Int       @default(1) // 1-6
  // Status: DRAFT → SENT → DETAILS_CONFIRMED → SLA_SIGNED → INVOICE_GENERATED → PAYMENT_DONE → ONBOARDING_COMPLETE → ACTIVATED
  status      String    @default("DRAFT")
  expiresAt   DateTime
  viewedAt    DateTime?
  acceptedAt  DateTime?

  // Links to created records
  clientId  String?
  invoiceId String?

  // Creator tracking
  createdById   String
  createdByRole String? // SALES, ACCOUNTS, ADMIN
  entityType    String  @default("BRANDING_PIONEERS") // ATZ_MEDAPPZ, BRANDING_PIONEERS

  // Link to AccountOnboardingDetails
  onboardingDetails AccountOnboardingDetails?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([token])
  @@index([currentStep])
  @@index([createdById])
}

