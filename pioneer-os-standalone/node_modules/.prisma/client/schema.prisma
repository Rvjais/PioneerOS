// Tokens for password reset via WhatsApp or Email
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String    @default("EMAIL") // EMAIL or WHATSAPP
  purpose   String    @default("RESET") // RESET or SET_PASSWORD (first-time)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// SUPER ADMIN API MANAGEMENT
// ============================================

// Agency-level API credentials managed by Super Admin
model AgencyApiCredential {
  id             String                  @id @default(cuid())
  provider       String // GOOGLE, META, LINKEDIN, TWITTER, RAZORPAY, STRIPE, RESEND, OPENROUTER, WBIZTOOL
  credentialType String // OAUTH, API_KEY, WEBHOOK
  name           String // Display name
  credentials    String // Encrypted JSON: { clientId, clientSecret, apiKey, etc. }
  status         String                  @default("ACTIVE") // ACTIVE, INVALID, EXPIRED, DISABLED
  environment    String                  @default("PRODUCTION") // PRODUCTION, SANDBOX
  lastVerifiedAt DateTime?
  lastVerifiedBy String?
  lastError      String?
  usageCount     Int                     @default(0)
  lastUsedAt     DateTime?
  createdAt      DateTime                @default(now())
  createdBy      String?
  updatedAt      DateTime                @updatedAt
  updatedBy      String?
  auditLogs      ApiCredentialAuditLog[]

  @@unique([provider, environment])
  @@index([provider])
  @@index([status])
}

// Agency service accounts for platform integrations
model AgencyServiceAccount {
  id          String   @id @default(cuid())
  platform    String // GOOGLE, META, LINKEDIN
  serviceType String // GOOGLE_ANALYTICS, GOOGLE_SEARCH_CONSOLE, META_PAGE, etc.
  email       String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([platform, serviceType])
}

// OAuth access requests for client connections
model OAuthAccessRequest {
  id                 String    @id @default(cuid())
  clientId           String
  client             Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform           String
  serviceType        String
  targetEmail        String
  status             String    @default("PENDING") // PENDING, GRANTED, DENIED
  instructionsSentAt DateTime?
  accessVerifiedAt   DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([clientId])
  @@index([status])
}

// Audit log for credential changes
model ApiCredentialAuditLog {
  id           String              @id @default(cuid())
  credentialId String
  credential   AgencyApiCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  action       String // CREATE, UPDATE, DELETE, ROTATE, VERIFY, VIEW
  fieldChanged String?
  userId       String
  userIp       String?
  success      Boolean
  errorMessage String?
  createdAt    DateTime            @default(now())

  @@index([credentialId])
  @@index([createdAt])
}

// ============================================
// CLIENT REPORTING SYSTEM
// ============================================

// Manual or OAuth-connected platform accounts for clients
model ClientPlatformAccount {
  id             String                @id @default(cuid())
  clientId       String
  client         Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform       String // GOOGLE_ANALYTICS, GOOGLE_SEARCH_CONSOLE, GOOGLE_ADS, META_ADS, META_SOCIAL, LINKEDIN, YOUTUBE
  accountId      String // Platform-specific account/property ID
  accountName    String
  accessType     String // OAUTH, MANUAL, DELEGATED
  isActive       Boolean               @default(true)
  lastSyncAt     DateTime?
  lastSyncStatus String? // SUCCESS, FAILED, PENDING
  syncError      String?
  metadata       String? // JSON - Platform-specific settings
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  createdBy      String?
  metrics        PlatformMetricEntry[]

  @@unique([clientId, platform, accountId])
  @@index([clientId])
  @@index([platform])
  @@index([isActive])
}

// Individual metric entries for reporting
model PlatformMetricEntry {
  id             String                @id @default(cuid())
  accountId      String
  account        ClientPlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date           DateTime
  metricType     String // sessions, users, pageviews, impressions, clicks, cost, conversions, etc.
  value          Float
  dimension      String? // Optional dimension (campaign, source, page, etc.)
  dimensionValue String?
  importSource   String // OAUTH_SYNC, CSV_IMPORT, EXCEL_IMPORT, MANUAL_ENTRY, PASTE_IMPORT
  importBatchId  String?
  createdAt      DateTime              @default(now())
  createdBy      String?

  @@index([accountId, date])
  @@index([accountId, metricType])
  @@index([importBatchId])
  @@index([date])
}

// Track data import batches for audit and rollback
model DataImportBatch {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform    String
  accountId   String? // Optional reference to specific account
  importType  String // CSV, EXCEL, MANUAL, PASTE
  fileName    String?
  totalRows   Int
  successRows Int
  failedRows  Int
  errorLog    String? // JSON - array of errors with row numbers
  status      String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  createdAt   DateTime  @default(now())
  createdBy   String
  completedAt DateTime?

  @@index([clientId])
  @@index([status])
  @@index([platform])
  @@index([createdAt])
}

// ============================================
// CLIENT PORTAL ENHANCEMENTS
// ============================================

// Portal User Invitations
model ClientUserInvitation {
  id          String      @id @default(cuid())
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  email       String
  name        String
  role        String      @default("SECONDARY") // PRIMARY, SECONDARY, VIEWER
  token       String      @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String?
  invitedBy   ClientUser? @relation("InvitationInviter", fields: [invitedById], references: [id])
  status      String      @default("PENDING") // PENDING, ACCEPTED, EXPIRED, CANCELLED

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([token])
  @@index([status])
  @@index([email])
}

// Portal User Activity Logs
model ClientUserActivity {
  id           String     @id @default(cuid())
  clientUserId String
  clientUser   ClientUser @relation(fields: [clientUserId], references: [id], onDelete: Cascade)
  action       String // LOGIN, LOGOUT, VIEW_DOCUMENT, DOWNLOAD, APPROVE, REJECT, UPDATE_PROFILE, etc.
  resource     String? // What was accessed (e.g., "document:123", "report:456")
  resourceType String? // DOCUMENT, REPORT, CREDENTIAL, APPROVAL, PROFILE, etc.
  details      String? // JSON - additional context
  ipAddress    String?
  userAgent    String?

  createdAt DateTime @default(now())

  @@index([clientUserId])
  @@index([action])
  @@index([createdAt])
}

// Portal Notifications
model PortalNotification {
  id           String      @id @default(cuid())
  clientId     String
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientUserId String?
  clientUser   ClientUser? @relation(fields: [clientUserId], references: [id], onDelete: Cascade)

  title    String
  message  String
  type     String @default("INFO") // INFO, SUCCESS, WARNING, ALERT, ACTION_REQUIRED
  category String @default("GENERAL") // GENERAL, INVOICE, REPORT, APPROVAL, MEETING, DELIVERABLE

  actionUrl   String? // Link to relevant page
  actionLabel String? // Button text (e.g., "View Report", "Approve Now")

  isRead Boolean   @default(false)
  readAt DateTime?

  // Source tracking
  sourceType String? // SYSTEM, USER, AUTOMATION
  sourceId   String? // Reference to source entity

  expiresAt DateTime? // Optional expiration

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([clientUserId])
  @@index([isRead])
  @@index([type])
  @@index([category])
  @@index([createdAt])
  @@index([expiresAt])
}

// Client Documents (File Sharing)
model ClientDocument {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String  @default("GENERAL") // GENERAL, CONTRACT, REPORT, INVOICE, BRAND_ASSET, DELIVERABLE, OTHER

  fileUrl  String
  fileType String // pdf, doc, xls, png, jpg, etc.
  fileSize Int // in bytes

  // Version tracking
  version           Int     @default(1)
  previousVersionId String?

  // Upload info
  uploadedById    String?
  uploadedBy      ClientUser? @relation("DocumentUploader", fields: [uploadedById], references: [id])
  uploadedByStaff String? // Staff user ID if uploaded by agency

  // Access control
  isPublic      Boolean @default(true) // Visible to all portal users
  allowDownload Boolean @default(true)

  // Sharing
  sharedWith String? // JSON array of clientUserId if private

  expiresAt DateTime? // Optional expiration for temporary documents

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([category])
  @@index([uploadedById])
  @@index([createdAt])
}

// Client Announcements (Agency -> Clients)
model ClientAnnouncement {
  id String @id @default(cuid())

  title    String
  content  String // Rich text / markdown
  type     String @default("INFO") // INFO, UPDATE, MAINTENANCE, ALERT, PROMOTION
  priority String @default("NORMAL") // LOW, NORMAL, HIGH, URGENT

  // Targeting
  targetAll   Boolean @default(false) // Show to all clients
  clientId    String? // Specific client (if not targetAll)
  client      Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  targetTiers String? // JSON array of tiers: ["PREMIUM", "ENTERPRISE"]

  // Display
  isPinned    Boolean @default(false)
  imageUrl    String?
  actionUrl   String?
  actionLabel String?

  // Scheduling
  publishAt DateTime  @default(now())
  expiresAt DateTime?

  // Author
  createdById String // Staff user ID

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([isActive])
  @@index([publishAt])
  @@index([type])
  @@index([priority])
}

// Client Goals (KPI Tracking)
model ClientGoal {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String  @default("MARKETING") // MARKETING, LEADS, REVENUE, TRAFFIC, ENGAGEMENT, CUSTOM

  // Goal definition
  metricType   String // leads, revenue, traffic, followers, engagement_rate, etc.
  targetValue  Float
  currentValue Float   @default(0)
  unit         String? // e.g., "leads", "INR", "users", "%"

  // Period
  periodType String   @default("MONTHLY") // WEEKLY, MONTHLY, QUARTERLY, YEARLY, CUSTOM
  startDate  DateTime
  endDate    DateTime

  // Status
  status     String    @default("IN_PROGRESS") // NOT_STARTED, IN_PROGRESS, COMPLETED, MISSED
  achievedAt DateTime?

  // Display
  isVisible    Boolean @default(true) // Visible in client portal
  displayOrder Int     @default(0)
  color        String? // For UI display

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([category])
  @@index([periodType])
  @@index([endDate])
}

// Content Approval Workflow
model ContentApproval {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        String  @default("CONTENT") // CONTENT, CREATIVE, AD, CAMPAIGN, REPORT, OTHER

  // Content details
  contentUrl  String? // Link to content (e.g., Canva, Google Doc)
  previewUrl  String? // Preview image URL
  attachments String? // JSON array of file URLs

  // Approval workflow
  status   String    @default("PENDING") // PENDING, APPROVED, REJECTED, REVISION_REQUESTED, CANCELLED
  priority String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  dueDate  DateTime?

  // Reviewer info
  reviewedById String?
  reviewedBy   ClientUser? @relation("ApprovalReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?

  // Revision tracking
  revisionCount Int     @default(0)
  revisionNotes String? // JSON array of revision history

  // Creator (staff)
  createdById String // Staff user ID

  // Notifications
  reminderSent   Boolean   @default(false)
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([dueDate])
  @@index([reviewedById])
}

// ============================================
// CLIENT ACCESS REQUESTS & WEB TEAM WORKFLOW
// ============================================

// Client Access Request - allows employees to request access to clients
model ClientAccessRequest {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requestedById   String
  requestedBy     User      @relation("ClientAccessRequester", fields: [requestedById], references: [id])
  requestedRole   String // TEAM_MEMBER, ACCOUNT_MANAGER, etc.
  purpose         String?
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById    String?
  approvedBy      User?     @relation("ClientAccessApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientId])
  @@index([requestedById])
  @@index([status])
}

// Web Project Phase - track project phases for web team clients
model WebProjectPhase {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  phase       String // CONTENT, DESIGN, MEDIA, DEVELOPMENT, TESTING, DEPLOYMENT
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, SKIPPED
  assignedTo  String?
  user        User?     @relation(fields: [assignedTo], references: [id])
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  proofUrl    String?
  order       Int // 1-6 for phase order
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([clientId, phase])
  @@index([clientId])
  @@index([phase])
}

// Maintenance Contract - track maintenance/hosting contracts for web clients
model MaintenanceContract {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  type         String // MONTHLY_MAINTENANCE, ANNUAL_HOSTING, DOMAIN_RENEWAL, AMC
  startDate    DateTime
  endDate      DateTime
  renewalDate  DateTime?
  amount       Float
  status       String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED, RENEWED
  autoRenew    Boolean   @default(false)
  reminderSent Boolean   @default(false)
  notes        String?

  // Domain tracking
  domainName       String?
  domainRegistrar  String? // GoDaddy, Namecheap, Google Domains
  domainExpiryDate DateTime?

  // Server/Hosting tracking
  serverProvider   String? // DigitalOcean, AWS, Hostinger, Vercel
  serverExpiryDate DateTime?
  serverPlan       String? // Basic, Pro, Enterprise

  // Billing cycle for maintenance
  billingCycle    String    @default("ANNUAL") // MONTHLY, QUARTERLY, ANNUAL
  nextBillingDate DateTime?

  // AMC Hour tracking
  allocatedHours  Float? // Total hours included in contract
  usedHours       Float  @default(0) // Hours used so far
  hourlyRateAfter Float? // Rate for hours beyond allocation

  // Reminder tracking
  expiryReminderSent Boolean   @default(false)
  reminderSentAt     DateTime?

  // Maintenance Logs
  maintenanceLogs MaintenanceLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([renewalDate])
  @@index([domainExpiryDate])
  @@index([serverExpiryDate])
}

// ============================================
// SERVICE CHANGE REQUESTS & ANNEXURES
// ============================================

// Track client requests to add/remove/modify services (from onboarding or post-onboarding)
model ServiceChangeRequest {
  id         String  @id @default(cuid())
  proposalId String?
  clientId   String?

  // Request details
  type        String // ADD_SERVICE, REMOVE_SERVICE, MODIFY_SCOPE
  serviceId   String? // Which service (from SERVICES constant)
  serviceName String
  reason      String? // Client's note/reason

  // Status workflow
  status String @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, REJECTED, IMPLEMENTED

  // Manager review
  reviewedAt   DateTime?
  reviewedBy   String?
  managerNotes String?

  // Pricing (filled by manager/accounts on approval)
  priceImpact   Float? // Change in monthly fee
  effectiveFrom DateTime? // Month from which change applies

  // Annexure tracking
  annexureNumber String? // Auto-generated: ANX-001, ANX-002, etc.
  annexureData   String? // JSON: full amendment details for SLA annexure

  requestedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([proposalId])
  @@index([clientId])
  @@index([status])
}

// ============================================
// SERVICE TERMINATION
// ============================================

// Service Termination - Track client service termination requests with 30-day notice
model ServiceTermination {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Request Details
  requestedBy String // ClientUser ID who initiated
  requestedAt DateTime @default(now())
  reason      String? // Why they're leaving
  feedback    String? // Additional feedback

  // Notice Period
  noticeStartDate DateTime @default(now())
  noticeEndDate   DateTime // +30 days from start
  lastServiceDate DateTime // Same as noticeEndDate

  // Payment Calculation
  monthlyFee       Float // Captured at request time
  daysInMonth      Int // Days in the termination month
  daysServed       Int // Days from start of billing to lastServiceDate
  proRataAmount    Float // Calculated: (monthlyFee / daysInMonth) * daysServed
  proRataBreakdown String? // JSON: detailed breakdown by month
  pendingDues      Float // Any outstanding invoices
  totalDue         Float // proRataAmount + pendingDues
  amountPaid       Float     @default(0)
  paymentCleared   Boolean   @default(false)
  paymentClearedAt DateTime?

  // Handover
  handoverCallScheduled Boolean   @default(false)
  handoverCallDate      DateTime?
  handoverCallCompleted Boolean   @default(false)
  handoverCallNotes     String?
  handoverMeetingId     String? // Reference to Meeting record

  // Data Export
  dataExportEnabled Boolean   @default(false) // Enabled when payment cleared
  dataExportedAt    DateTime?
  dataExportUrl     String? // Generated export file URL

  // Status
  status          String    @default("PENDING") // PENDING, ACTIVE, HANDOVER, COMPLETED, CANCELLED
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelledReason String?

  // Admin tracking
  processedBy String? // User ID of admin who processed
  processedAt DateTime?
  adminNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([noticeEndDate])
  @@index([paymentCleared])
}

// ============================================
// WEB CLIENT PORTAL
// ============================================

// Website Sitemap - Track pages for web client projects
model WebsiteSitemap {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  pageName    String // "Home", "About Us", "Contact"
  pageSlug    String // "/", "/about", "/contact"
  pageUrl     String? // Full URL once live
  pageType    String  @default("STATIC") // STATIC, DYNAMIC, BLOG, PRODUCT, LANDING
  description String? // Page purpose/content description

  status String @default("PLANNED") // PLANNED, IN_DESIGN, IN_DEVELOPMENT, REVIEW, APPROVED, LIVE
  order  Int    @default(0)

  wireframeUrl String?
  designUrl    String? // Figma/XD link
  previewUrl   String? // Staging URL for client review

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedback PageFeedback[]

  @@unique([clientId, pageSlug])
  @@index([clientId])
  @@index([status])
}

// Page Feedback - Feedback on website pages from clients and team
model PageFeedback {
  id        String         @id @default(cuid())
  sitemapId String
  sitemap   WebsiteSitemap @relation(fields: [sitemapId], references: [id], onDelete: Cascade)

  // Author (client user OR web team member)
  clientUserId String?
  clientUser   ClientUser? @relation(fields: [clientUserId], references: [id])
  userId       String? // Web team member
  user         User?       @relation(fields: [userId], references: [id])

  feedbackType  String  @default("COMMENT") // COMMENT, CHANGE_REQUEST, APPROVAL, QUESTION
  message       String
  screenshotUrl String?
  status        String  @default("PENDING") // PENDING, ACKNOWLEDGED, RESOLVED

  // Threading
  parentId String?
  parent   PageFeedback?  @relation("FeedbackThread", fields: [parentId], references: [id])
  replies  PageFeedback[] @relation("FeedbackThread")

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([sitemapId])
  @@index([status])
  @@index([clientUserId])
  @@index([userId])
}

// Web Onboarding - Questionnaire for new web clients
model WebOnboarding {
  id       String  @id @default(cuid())
  token    String  @unique @default(cuid())
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  status String @default("PENDING") // PENDING, SUBMITTED, REVIEWED, CONVERTED

  // Business Info
  businessName        String?
  businessDescription String?
  industry            String?
  targetAudience      String? // JSON

  // Website Requirements
  websiteType   String? // ECOMMERCE, CORPORATE, PORTFOLIO, LANDING, BLOG, CUSTOM
  requiredPages String? // JSON: ["Home", "About", "Services", "Contact"]
  features      String? // JSON: ["Contact Form", "Blog", "E-commerce", "Chat"]

  // Design Preferences
  colorPreferences String? // JSON: {primary: "#xxx", secondary: "#xxx"}
  stylePreference  String? // MODERN, MINIMAL, BOLD, CLASSIC, PLAYFUL
  referenceUrls    String? // JSON array of websites they like

  // Assets
  hasLogo       Boolean @default(false)
  hasContent    Boolean @default(false)
  logoUrl       String?
  brandGuideUrl String?

  // Domain/Hosting
  hasDomain       Boolean @default(false)
  domainName      String?
  hasHosting      Boolean @default(false)
  hostingProvider String?

  // Contact
  contactName  String?
  contactEmail String?
  contactPhone String?

  submittedAt DateTime?
  reviewedBy  String?
  convertedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([status])
  @@index([clientId])
}

// ============================================
// WEB TEAM INFRASTRUCTURE MANAGEMENT
// ============================================

// Domain Management - Track client domains
model Domain {
  id               String    @id @default(cuid())
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  domainName       String    @unique
  registrar        String // GoDaddy, Namecheap, Google Domains, etc.
  registrationDate DateTime
  expiryDate       DateTime
  autoRenew        Boolean   @default(true)
  nameservers      String? // JSON array of nameservers
  dnsProvider      String? // Cloudflare, Route53, etc.
  sslStatus        String    @default("NONE") // ACTIVE, EXPIRED, NONE, PENDING
  sslExpiryDate    DateTime?
  sslProvider      String? // Let's Encrypt, Cloudflare, etc.
  purchasedBy      String    @default("AGENCY") // CLIENT, AGENCY
  annualCost       Float?
  loginUrl         String? // Login URL for registrar
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([clientId])
  @@index([expiryDate])
  @@index([sslStatus])
  @@index([sslExpiryDate])
}

// Hosting Account Management - Track client hosting
model HostingAccount {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider       String // AWS, DigitalOcean, Hostinger, Vercel, etc.
  planType       String // Shared, VPS, Dedicated, Cloud, Serverless
  planName       String? // Basic, Pro, Enterprise, etc.
  serverLocation String? // US-East, EU-West, AP-South, etc.
  monthlyCost    Float
  renewalDate    DateTime
  storageGB      Float?
  bandwidthGB    Float?
  ipAddress      String?
  cpanelUrl      String?
  sshAccess      Boolean  @default(false)
  sshHost        String?
  sshPort        Int?
  purchasedBy    String   @default("AGENCY") // CLIENT, AGENCY
  status         String   @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED, PENDING
  loginUrl       String? // Login URL for hosting panel
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId])
  @@index([renewalDate])
  @@index([status])
}

// Maintenance Log - Track AMC hours and activities
model MaintenanceLog {
  id            String              @id @default(cuid())
  contractId    String
  contract      MaintenanceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  date          DateTime            @default(now())
  hoursSpent    Float
  description   String
  performedById String // User ID who performed the work
  category      String // BUG_FIX, UPDATE, SECURITY, BACKUP, CONTENT_UPDATE, FEATURE, OTHER
  billable      Boolean             @default(true)
  ticketId      String? // Reference to support ticket if any
  attachments   String? // JSON array of attachment URLs
  clientVisible Boolean             @default(true) // Show in client portal
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([contractId])
  @@index([date])
  @@index([category])
  @@index([performedById])
}

// Web Reimbursement - Track expenses paid by team for clients
model WebReimbursement {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type            String // DOMAIN, HOSTING, SSL, PLUGIN, THEME, SUBSCRIPTION, OTHER
  description     String
  vendor          String? // GoDaddy, AWS, etc.
  amount          Float
  currency        String    @default("INR")
  paidById        String // User ID who paid
  paidDate        DateTime
  receiptUrl      String?
  invoiceUrl      String? // Our invoice to client
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED, BILLED, REIMBURSED
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  reimbursedDate  DateTime?
  billedToClient  Boolean   @default(false)
  clientInvoiceId String? // Reference to client invoice if billed
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([paidById])
  @@index([paidDate])
}

// Upsell Opportunity - Track potential upsells to clients
model UpsellOpportunity {
  id             String    @id @default(cuid())
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type           String // AMC, SEO, MARKETING, REDESIGN, ECOMMERCE, APP, PERFORMANCE, SECURITY
  title          String
  description    String?
  estimatedValue Float
  probability    Int       @default(50) // 0-100
  status         String    @default("IDENTIFIED") // IDENTIFIED, QUALIFIED, PITCHED, NEGOTIATING, WON, LOST
  assignedToId   String? // User ID
  source         String? // AUTO, MANUAL, CLIENT_REQUEST
  triggerReason  String? // What triggered this upsell (e.g., "No AMC after launch")
  pitchedDate    DateTime?
  pitchNotes     String?
  followUpDate   DateTime?
  wonDate        DateTime?
  lostDate       DateTime?
  lostReason     String?
  wonValue       Float? // Actual value if different from estimated
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([type])
  @@index([assignedToId])
  @@index([followUpDate])
}

// Web Project - Main project entity for web team
model WebProject {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  description String?
  projectType String  @default("NEW_WEBSITE") // NEW_WEBSITE, REDESIGN, MIGRATION, ECOMMERCE, LANDING_PAGE
  status      String  @default("PIPELINE") // PIPELINE, IN_PROGRESS, ON_HOLD, COMPLETED, CANCELLED
  priority    String  @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT

  // Timeline
  startDate     DateTime?
  targetEndDate DateTime?
  actualEndDate DateTime?

  // Cost Tracking
  quotedAmount   Float?
  finalAmount    Float?
  estimatedHours Float?
  actualHours    Float?
  profitMargin   Float?

  // Tech Stack
  platform  String? // WordPress, Shopify, Custom, etc.
  techStack String? // JSON array of technologies

  // URLs
  stagingUrl    String?
  productionUrl String?
  repositoryUrl String?
  figmaUrl      String?

  // Assignments
  projectManagerId String?
  leadDeveloperId  String?
  leadDesignerId   String?

  // Phase Tracking
  currentPhase  String  @default("CONTENT") // CONTENT, DESIGN, MEDIA, DEVELOPMENT, TESTING, DEPLOYMENT
  phaseProgress String? // JSON object with phase completion percentages

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  phases          WebProjectPhaseItem[]
  bugReports      WebBugReport[]
  changeRequests  WebChangeRequest[]
  designApprovals WebDesignApproval[]
  timeEntries     WebProjectTimeEntry[]

  @@index([clientId])
  @@index([status])
  @@index([currentPhase])
  @@index([projectManagerId])
}

// Web Project Phase Item - Individual phase tracking with checklists
model WebProjectPhaseItem {
  id        String     @id @default(cuid())
  projectId String
  project   WebProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase     String // CONTENT, DESIGN, MEDIA, DEVELOPMENT, TESTING, DEPLOYMENT
  status    String     @default("PENDING") // PENDING, IN_PROGRESS, IN_REVIEW, APPROVED, COMPLETED
  order     Int

  // Assignments
  assignedToId String?

  // Timeline
  startedAt    DateTime?
  completedAt  DateTime?
  approvedAt   DateTime?
  approvedById String? // Client user or team member who approved

  // Checklist
  checklist String? // JSON array of checklist items with completion status

  // Client Approval
  requiresApproval Boolean @default(true)
  approvalNotes    String?
  revisionCount    Int     @default(0)

  // Proof/Deliverables
  deliverableUrls String? // JSON array of URLs for this phase

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, phase])
  @@index([projectId])
  @@index([status])
  @@index([assignedToId])
}

// Web Bug Report - Client bug submissions
model WebBugReport {
  id           String     @id @default(cuid())
  projectId    String
  project      WebProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientUserId String? // If submitted by client

  title         String
  description   String
  pageUrl       String? // URL where bug occurs
  screenshotUrl String?
  browserInfo   String? // Auto-detected browser/device info
  priority      String  @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status        String  @default("OPEN") // OPEN, CONFIRMED, IN_PROGRESS, RESOLVED, CLOSED, WONT_FIX

  // Assignment
  assignedToId String?

  // Resolution
  resolvedAt     DateTime?
  resolvedById   String?
  resolution     String? // Description of how it was fixed
  fixedInVersion String?

  // Tracking
  estimatedHours Float?
  actualHours    Float?
  isBillable     Boolean @default(false) // For post-AMC bugs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([clientUserId])
}

// Web Change Request - Client change requests
model WebChangeRequest {
  id           String     @id @default(cuid())
  projectId    String
  project      WebProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientUserId String? // If submitted by client

  title         String
  description   String
  type          String  @default("MINOR") // MINOR, MAJOR, FEATURE, ENHANCEMENT
  pageUrl       String?
  screenshotUrl String?

  // Estimation
  estimatedHours Float?
  estimatedCost  Float?

  // Approval (for billable changes)
  requiresApproval Boolean   @default(false)
  status           String    @default("PENDING") // PENDING, ESTIMATED, CLIENT_APPROVED, IN_PROGRESS, COMPLETED, REJECTED
  clientApprovedAt DateTime?
  rejectionReason  String?

  // Assignment
  assignedToId String?

  // Completion
  completedAt   DateTime?
  completedById String?
  actualHours   Float?
  actualCost    Float?

  // Billing
  isBillable Boolean @default(false)
  invoiced   Boolean @default(false)
  invoiceId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([type])
  @@index([assignedToId])
  @@index([clientUserId])
}

// Web Design Approval - Design approval workflow
model WebDesignApproval {
  id        String     @id @default(cuid())
  projectId String
  project   WebProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title        String // "Homepage Design v1", "About Page Design v2"
  description  String?
  designUrl    String // Figma, XD, or image URL
  thumbnailUrl String?
  phase        String // Which phase this design is for
  version      Int     @default(1)

  status String @default("PENDING") // PENDING, APPROVED, CHANGES_REQUESTED, SUPERSEDED

  // Client feedback
  clientUserId   String? // Who reviewed
  reviewedAt     DateTime?
  clientFeedback String?
  feedbackPins   String? // JSON array of pin comments on design

  // Internal notes
  designerId    String? // Who created the design
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([phase])
  @@index([designerId])
}

// Web Project Time Entry - Track time spent on projects
model WebProjectTimeEntry {
  id        String     @id @default(cuid())
  projectId String
  project   WebProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String

  date        DateTime @default(now())
  hours       Float
  description String
  phase       String? // Which phase this work relates to
  category    String? // DESIGN, DEVELOPMENT, TESTING, MEETING, OTHER

  // For billing
  isBillable Boolean @default(true)
  invoiced   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([date])
}

// ============================================
// DAILY MEETING (HUDDLE) - MANDATORY
// ============================================

// Daily check-in that must be filled before accessing dashboard
model DailyMeeting {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime // Normalized to start of day

  // Check-in time
  checkInTime DateTime @default(now())

  // Yesterday's Work
  yesterdayWork     String // JSON array of completed tasks
  yesterdayBlockers String? // Any blockers faced

  // Today's Plan
  todayPlan      String // JSON array of planned tasks
  todayClients   String // JSON array of client IDs/names
  estimatedHours Float  @default(8)

  // Quick Health Check
  workload        String  @default("NORMAL") // LOW, NORMAL, HIGH, OVERLOADED
  mood            String  @default("GOOD") // GREAT, GOOD, OKAY, STRESSED
  needsHelp       Boolean @default(false)
  helpDescription String?

  // Location
  workLocation String @default("OFFICE") // OFFICE, WFH, CLIENT_SITE, FIELD

  // Compliance
  isLate     Boolean @default(false) // Filled after 11:00 AM
  autoMarked Boolean @default(false) // System auto-marked as absent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([isLate])
}

// Meeting Compliance Tracking (Monthly rollup)
// NOTE: Reserved for future use — not yet connected to any API
model MeetingCompliance {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month  DateTime // First of month

  // Daily meetings
  dailyMeetingsExpected Int @default(0)
  dailyMeetingsFilled   Int @default(0)
  dailyMeetingsLate     Int @default(0)
  dailyMeetingsMissed   Int @default(0)
  autoMarkedLeaves      Int @default(0)

  // Tactical meeting
  tacticalFilled   Boolean   @default(false)
  tacticalFilledAt DateTime?
  tacticalIsLate   Boolean   @default(false)

  // Strategic meeting (only applicable for quarter-end months)
  strategicFilled   Boolean   @default(false)
  strategicFilledAt DateTime?
  strategicIsLate   Boolean   @default(false)

  // Overall compliance score (0-100)
  complianceScore Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
  @@index([month])
  @@index([complianceScore])
}

// AI Data Extraction Sessions
model AIExtractionSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Context
  targetType String // TACTICAL_MEETING, CLIENT_REPORT
  targetId   String? // TacticalMeeting ID or TacticalKPIEntry ID
  clientId   String?
  client     Client? @relation(fields: [clientId], references: [id])

  // Conversation
  messages String // JSON array of conversation messages

  // Extracted data
  extractedData String? // JSON object of extracted fields
  confidence    Float   @default(0) // 0-1 confidence score

  // Status
  status      String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, ABANDONED
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([targetType])
  @@index([status])
}

// ============================================
// SYSTEM SETTINGS
// ============================================

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String // JSON value
  category    String // general, notifications, attendance, meetings, security, integrations
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([key])
}

// ============================================
// SEO MODULE
// ============================================

model SeoKeyword {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation("SeoKeywords", fields: [clientId], references: [id], onDelete: Cascade)
  keyword      String
  location     String   @default("India")
  searchVolume Int      @default(0)
  currentRank  Int?
  previousRank Int?
  targetPage   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rankHistory SeoRankHistory[]

  @@index([clientId])
  @@index([clientId, keyword])
}

model SeoRankHistory {
  id        String     @id @default(cuid())
  keywordId String
  keyword   SeoKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  rank      Int
  date      DateTime   @default(now())

  @@index([keywordId])
  @@index([keywordId, date])
}

model SeoBacklink {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation("SeoBacklinks", fields: [clientId], references: [id], onDelete: Cascade)
  targetUrl       String
  anchorText      String
  backlinkSource  String
  domainAuthority Int      @default(0)
  status          String   @default("SUBMITTED") // SUBMITTED, LIVE, REJECTED
  liveUrl         String?
  submittedDate   DateTime @default(now())
  createdById     String?
  createdBy       User?    @relation("BacklinkCreator", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
  @@index([status])
}

model SeoContent {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation("SeoContent", fields: [clientId], references: [id], onDelete: Cascade)
  blogTopic     String
  targetKeyword String?
  writerId      String?
  writer        User?     @relation("ContentWriter", fields: [writerId], references: [id])
  status        String    @default("DRAFT") // DRAFT, IN_REVIEW, PUBLISHED
  wordCount     Int       @default(0)
  publishedUrl  String?
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clientId])
  @@index([writerId])
  @@index([status])
}

model GbpProfile {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation("GbpProfiles", fields: [clientId], references: [id], onDelete: Cascade)
  profileName  String
  location     String
  category     String   @default("Business")
  totalReviews Int      @default(0)
  rating       Float    @default(0)
  status       String   @default("ACTIVE") // ACTIVE, NEEDS_ATTENTION, OPTIMIZING
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts   GbpPost[]
  metrics GbpMetric[]

  @@index([clientId])
}

model GbpPost {
  id          String     @id @default(cuid())
  profileId   String
  profile     GbpProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  postType    String     @default("UPDATE") // UPDATE, OFFER, EVENT, PRODUCT
  content     String
  proofLink   String?
  views       Int        @default(0)
  publishedAt DateTime   @default(now())
  createdAt   DateTime   @default(now())

  @@index([profileId])
}

model GbpMetric {
  id            String     @id @default(cuid())
  profileId     String
  profile       GbpProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  month         String // "2026-03"
  calls         Int        @default(0)
  directions    Int        @default(0)
  profileViews  Int        @default(0)
  websiteClicks Int        @default(0)
  monthlyPosts  Int        @default(0)
  createdAt     DateTime   @default(now())

  @@unique([profileId, month])
  @@index([profileId])
}

model SeoTask {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation("SeoTasks", fields: [clientId], references: [id], onDelete: Cascade)
  taskType     String // ON_PAGE, OFF_PAGE, TECHNICAL, CONTENT, REPORTING
  category     String?
  description  String
  assignedToId String?
  assignedTo   User?     @relation("SeoTaskAssignee", fields: [assignedToId], references: [id])
  reviewerId   String?
  reviewer     User?     @relation("SeoTaskReviewer", fields: [reviewerId], references: [id])
  priority     String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status       String    @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  deadline     DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([clientId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
}

// ============================================
// ADS DEPARTMENT MODELS
// ============================================

model Campaign {
  id           String  @id @default(cuid())
  clientId     String
  client       Client  @relation("ClientCampaigns", fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  platform     String // GOOGLE, META, LINKEDIN, YOUTUBE
  campaignType String? // SEARCH, DISPLAY, VIDEO, SHOPPING, PERFORMANCE_MAX, LEAD_GEN, TRAFFIC, ENGAGEMENT, BRAND_AWARENESS
  objective    String? // LEADS, CONVERSIONS, TRAFFIC, AWARENESS, ENGAGEMENT
  status       String  @default("DRAFT") // DRAFT, ACTIVE, PAUSED, COMPLETED, ARCHIVED
  externalId   String? // Platform-specific campaign ID

  // Budget
  dailyBudget   Float?
  monthlyBudget Float?
  totalBudget   Float?
  currency      String @default("INR")

  // Targeting
  targetAudience String? // JSON: demographics, interests, locations
  keywords       String? // JSON array for search campaigns
  placements     String? // JSON array for display campaigns

  // Performance (aggregated)
  impressions  Int    @default(0)
  clicks       Int    @default(0)
  conversions  Int    @default(0)
  leads        Int    @default(0)
  spend        Float  @default(0)
  cpc          Float?
  cpl          Float?
  ctr          Float?
  roas         Float?
  qualityScore Float?

  // Dates
  startDate DateTime?
  endDate   DateTime?

  // Relations
  adCreatives      AdCreative[]
  adSpendRecords   AdSpend[]
  abTests          ABTest[]
  conversionEvents ConversionEvent[]

  // Ownership
  assignedToId String?
  assignedTo   User?   @relation("CampaignAssignee", fields: [assignedToId], references: [id])
  createdById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([platform])
  @@index([status])
  @@index([assignedToId])
  @@index([clientId, platform, status])
}

model AdCreative {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clientId   String

  name     String
  type     String // IMAGE, VIDEO, CAROUSEL, TEXT, HTML5
  platform String // GOOGLE, META, LINKEDIN
  status   String @default("DRAFT") // DRAFT, PENDING_REVIEW, APPROVED, RUNNING, PAUSED, REJECTED

  // Creative content
  headline       String?
  description    String?
  callToAction   String?
  mediaUrl       String?
  thumbnailUrl   String?
  landingPageUrl String?

  // Performance
  impressions Int    @default(0)
  clicks      Int    @default(0)
  conversions Int    @default(0)
  ctr         Float?

  // Approval
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?

  // Versioning
  version  Int     @default(1)
  parentId String? // Previous version ID

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([clientId])
  @@index([status])
}

model AdSpend {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clientId   String

  date     DateTime
  platform String // GOOGLE, META, LINKEDIN
  amount   Float
  currency String   @default("INR")

  // Daily metrics
  impressions Int @default(0)
  clicks      Int @default(0)
  conversions Int @default(0)
  leads       Int @default(0)

  // Calculated
  cpc  Float?
  cpl  Float?
  ctr  Float?
  roas Float?

  createdAt DateTime @default(now())

  @@unique([campaignId, date])
  @@index([clientId])
  @@index([date])
  @@index([clientId, date])
  @@index([platform, date])
}

model BudgetAllocation {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation("ClientBudgets", fields: [clientId], references: [id], onDelete: Cascade)

  month           DateTime // First day of month
  platform        String // GOOGLE, META, LINKEDIN, ALL
  allocatedAmount Float
  spentAmount     Float    @default(0)
  currency        String   @default("INR")

  // Pacing
  dailyTarget  Float?
  pacingStatus String @default("ON_TRACK") // ON_TRACK, UNDERSPEND, OVERSPEND

  // Approval
  approvedById String?
  approvedAt   DateTime?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, month, platform])
  @@index([clientId])
  @@index([month])
}

model ABTest {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clientId   String

  name       String
  hypothesis String?
  status     String  @default("RUNNING") // RUNNING, COMPLETED, CANCELLED
  testType   String // CREATIVE, AUDIENCE, BIDDING, LANDING_PAGE, COPY

  // Variants (JSON: [{name, description, metrics}])
  variantA String // JSON
  variantB String // JSON
  winner   String? // A, B, or INCONCLUSIVE

  // Results
  confidenceLevel Float?
  startDate       DateTime  @default(now())
  endDate         DateTime?
  conclusion      String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([clientId])
  @@index([status])
}

model ConversionEvent {
  id         String    @id @default(cuid())
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  clientId   String

  eventName String // FORM_SUBMIT, PHONE_CALL, PURCHASE, SIGNUP, DOWNLOAD
  platform  String // GOOGLE, META, DIRECT, ORGANIC
  source    String? // Campaign name or source identifier

  // Lead info
  leadName  String?
  leadEmail String?
  leadPhone String?

  // Attribution
  adSpend Float? // Cost attributed to this conversion
  revenue Float? // Revenue from this conversion

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@index([campaignId])
  @@index([platform])
  @@index([occurredAt])
  @@index([clientId, occurredAt])
}
