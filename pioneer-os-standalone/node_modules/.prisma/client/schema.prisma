  isForfeited         Boolean @default(false)
}

model Attendance {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  date           DateTime  @default(now())
  checkIn        DateTime?
  checkOut       DateTime?
  biometricPunch Boolean   @default(false)
  myZenHours     Float     @default(0.0)
  huddleLate     Boolean   @default(false)
  status         String    @default("PRESENT") // PRESENT, ABSENT, HALF_DAY, WFH, LEAVE

  // Import tracking fields
  importBatchId   String?
  sourceType      String? // MANUAL, MYZEN_SYNC, BIOMETRIC_IMPORT, AI_PARSED
  rawSourceData   String? // Original line from import
  parseConfidence Float? // AI confidence score (0-1)
  importBatch     AttendanceImport? @relation(fields: [importBatchId], references: [id])

