  locations         String?
  targetAudience    String? // JSON
  competitors       String?
  usp               String?
  adBudget          String?
  retainerBudget    String?
  primaryGoals      String? // JSON array
  successMetrics    String?
  biggestChallenge  String?
  currentMarketing  String?
  whatWorked        String?
  whatDidntWork     String?
  preferredCallTime String?
  additionalInfo    String?
  prospectFormData  String? // JSON with all form answers

