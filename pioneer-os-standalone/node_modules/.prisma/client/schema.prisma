  totalIncentive Float @default(0)

  // Status
  status     String    @default("CALCULATED") // CALCULATED, APPROVED, PAID
  approvedBy String?
  approvedAt DateTime?
  paidAt     DateTime?

  // Notes
  deductions      Float   @default(0) // Any deductions (client attrition, etc.)
  deductionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
