// ============================================
// DAILY TASK PLANNER
// ============================================

model DailyTaskPlan {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime // The day this plan is for
  isWeeklyPlan Boolean  @default(false) // True if this is a Monday weekly planning

  // Status & Submission
  status                String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED
  submittedAt           DateTime? // When the plan was submitted (must be before 11am)
  submittedBeforeHuddle Boolean   @default(false) // True if submitted before 11am

  // Total hours tracking
  totalPlannedHours Float   @default(0)
  totalActualHours  Float   @default(0)
  hasUnder4Hours    Boolean @default(false) // Flag if worked under 4 hours

  tasks DailyTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([date])
  @@index([status])
}

model DailyTask {
  id     String        @id @default(cuid())
  planId String
  plan   DailyTaskPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Task Details
  clientId     String?
  client       Client? @relation("DailyTaskClient", fields: [clientId], references: [id], onDelete: SetNull)
  clientName   String? // Custom client name when client not in system (fallback)
  activityType String // Department-specific activity type
  description  String // Task description

  // Time Planning
  plannedStartTime DateTime? // When user plans to start this task
  plannedHours     Float     @default(1) // Estimated hours

  // Time Tracking (Actual)
  actualStartTime DateTime? // When task was actually started
  actualEndTime   DateTime? // When task was completed
  actualHours     Float? // Actual hours spent

  // Timestamps
  addedAt     DateTime  @default(now()) // When the task was added to plan
  startedAt   DateTime? // When status changed to IN_PROGRESS
  completedAt DateTime? // When status changed to COMPLETED

  // Status
  status          String  @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, BREAKDOWN
  isBreakdown     Boolean @default(false) // True if task was not completed same day
  breakdownReason String? // Reason for breakdown

  // Priority & Order
  priority  String @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  sortOrder Int    @default(0)

  // Notes & Deliverables
  notes       String?
  deliverable String? // What was delivered/output
  proofUrl    String? // URL link to proof (sheet, doc, drive link, etc.)
  remarks     String? // Remarks about task execution

  // Client Visibility
  clientVisible Boolean @default(false) // Whether this task should be visible to client
  workEntryId   String? // Link to auto-created WorkEntry for client visibility

  // Allocation
  allocatedById String? // Who allocated this task
  allocatedBy   User?   @relation("DailyTaskAllocator", fields: [allocatedById], references: [id], onDelete: SetNull)

  // Deadline & Rating
  deadline DateTime? // Task deadline
  rateTask Int? // Self-rating 1-5 stars

  // Company/Entity for this task
  company String? // Branding Pioneers, ATZ Medappz, BP Academy

  // Manager Reporting
  reportedToManager Boolean   @default(false) // Whether manager was notified of completion
  reportedAt        DateTime? // When manager was notified

  // Manager Review (Rating & Feedback)
  managerReviewed     Boolean   @default(false) // Whether manager has reviewed this task
  managerReviewedAt   DateTime? // When manager reviewed
  managerReviewedById String? // Manager who reviewed
  managerReviewedBy   User?     @relation("DailyTaskReviewer", fields: [managerReviewedById], references: [id], onDelete: SetNull)
  managerRating       Int? // Manager rating 1-5 stars
  managerFeedback     String? // Manager review comments/feedback

  // Client Communication Tracking
  clientCommunicated   Boolean   @default(false) // Whether client was notified of completion
  communicatedAt       DateTime? // When client was communicated
  communicatedVia      String? // WHATSAPP, EMAIL, CALL
  communicationMessage String? // The message that was sent

  // Goal alignment
  goalLinks TaskGoalLink[]

  // Breakthrough tracking (completed same day started = breakthrough)
  isBreakthrough Boolean @default(false)

  // Sales: Lead reference
  leadId String?
  lead   Lead?   @relation("DailyTaskLead", fields: [leadId], references: [id], onDelete: SetNull)

  // HR: Department/Employee target
  departmentTarget  String? // WEB, SEO, HR, etc.
  employeeTargetId  String? // Specific employee for HR tasks
  candidateTargetId String? // Specific candidate for recruitment tasks

  // Accounts: Task categorization
  accountsTaskType    String? // CLIENT_INVOICE, CLIENT_PAYMENT, COMPLIANCE, RECONCILIATION, TDS_FILING, VENDOR_PAYMENT
  complianceType      String? // GST_FILING, TDS_RETURN, PT_FILING, PF_FILING, ESI_FILING, AUDIT_PREP
  paymentReceivedDate DateTime? // For payment tracking in ledger
  invoiceNotifiedAt   DateTime? // When client portal was notified

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId, status])
  @@index([status])
  @@index([leadId])
  @@index([isBreakthrough])
}

