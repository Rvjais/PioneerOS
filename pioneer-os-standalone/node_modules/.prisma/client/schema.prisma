datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// SYSTEM UTILITIES
// ============================================

// Distributed lock for preventing duplicate execution
model DistributedLock {
  id         String   @id
  lockName   String   @unique
  acquiredAt DateTime @default(now())
  expiresAt  DateTime

  @@index([lockName])
  @@index([expiresAt])
}

// ============================================
// CORE USER & AUTHENTICATION
// ============================================

model User {
  id        String  @id @default(cuid())
  empId     String  @unique // BP-XXX
  firstName String
  lastName  String?
  phone     String  @unique
  email     String? @unique
  password  String?

  // Two-Factor Authentication
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String? // Encrypted TOTP secret
  twoFactorBackupCodes String? // Encrypted JSON array of backup codes
  twoFactorVerifiedAt  DateTime?

  role             String // SUPER_ADMIN, MANAGER, EMPLOYEE, FREELANCER, SALES, ACCOUNTS, INTERN
  department       String // WEB, SEO, ADS, SOCIAL, HR, ACCOUNTS, SALES, OPERATIONS
  employeeType     String    @default("FULL_TIME") // FULL_TIME, PART_TIME, FREELANCER, INTERN
  joiningDate      DateTime
  dateOfBirth      DateTime?
  status           String    @default("ACTIVE") // ACTIVE, PROBATION, PIP, INACTIVE
  bloodGroup       String?
  address          String?
  /// Comma-separated string of languages spoken, e.g. "English,Hindi,Marathi"
  languages        String? // comma-separated string
  /// Comma-separated string of AI tools used, e.g. "ChatGPT,Midjourney,Copilot"
  aiTools          String? // comma-separated string
  education        String?
  healthConditions String?
  capacity         Int       @default(50) // Monthly task capacity
  buddyId          String?
  buddy            User?     @relation("BuddySystem", fields: [buddyId], references: [id], onDelete: SetNull)
  buddies          User[]    @relation("BuddySystem")

  // Profile completion tracking
  profileCompletionStatus String    @default("INCOMPLETE") // INCOMPLETE, PENDING_HR, VERIFIED
  onboardingStep          Int       @default(0)
  hrVerifiedBy            String?
  hrVerifiedAt            DateTime?

  // Relations
  profile               Profile?
  rbcPot                RBC_Pot?
  attendance            Attendance[]
  violations            Violations[]
  accountability        AccountabilityCharter[]
  scores                PerformanceScore[]
  assignedTasks         Task[]                       @relation("TaskAssignee")
  createdTasks          Task[]                       @relation("TaskCreator")
  reviewedTasks         Task[]                       @relation("TaskReviewer")
  notifications         Notification[]
  clientAssignments     ClientTeamMember[]
  meetings              MeetingParticipant[]
  trainings             UserTraining[]
  certifications        UserCertification[]
  communicationLogs     CommunicationLog[]
  posts                 Post[]
  comments              Comment[]
  likes                 Like[]
  ideas                 Idea[]
  ideaVotes             IdeaVote[]
  recognition           Recognition[]                @relation("RecognitionReceiver")
  givenRecognition      Recognition[]                @relation("RecognitionGiver")
  leaveRequests         LeaveRequest[]
  documents             Document[]
  onboardingChecklist   EmployeeOnboardingChecklist?
  issues                Issue[]                      @relation("IssueAssignee")
  createdIssues         Issue[]                      @relation("IssueCreator")
  assignedLeads         Lead[]                       @relation("LeadAssignee")
  leadActivities        LeadActivity[]
  followUpReminders     FollowUpReminder[]
  nurturingActions      LeadNurturingAction[]        @relation("NurturingActionUser")
  salesHandovers        SalesHandover[]              @relation("SalesHandoverSales")
  accountsHandovers     SalesHandover[]              @relation("SalesHandoverAccounts")
  salesMeetings         SalesMeeting[]               @relation("SalesMeetingUser")
  salesWhatsAppMessages SalesWhatsAppMessage[]       @relation("SalesWhatsAppUser")
  salesDeals            SalesDeal[]                  @relation("SalesDealUser")
  salesDailyTasks       SalesDailyTask[]             @relation("SalesDailyTaskUser")
  allocatedDailyTasks   DailyTask[]                  @relation("DailyTaskAllocator")
  reviewedDailyTasks    DailyTask[]                  @relation("DailyTaskReviewer")
  supportTickets        SupportTicket[]              @relation("SupportTicketAssignee")
  ticketActivities      TicketActivity[]             @relation("TicketActivityUser")

  // Accountability & Incentives
  accountabilityScores AccountabilityScore[]
  workDeliverables     WorkDeliverable[]
  achievements         Achievement[]
  tacticalGoals        TacticalGoal[]
  incentivePayouts     IncentivePayout[]
  resourceComments     LearningResourceComment[]

  // Task Management
  taskComments TaskComment[]
  timeEntries  TimeEntry[]

  // Phase 2 Features
  arcadeTransactions ArcadePointTransaction[]
  arcadeRedemptions  ArcadeRedemption[]
  leaveBalances      LeaveBalance[]
  rbcAccruals        RBCAccrual[]
  rbcPayouts         RBCPayout[]
  pipPlans           PIPPlan[]                @relation("PIPEmployee")
  pipManagedPlans    PIPPlan[]                @relation("PIPManager")
  assetAssignments   AssetAssignment[]
  exitProcesses      ExitProcess[]
  fnfSettlements     FnFSettlement[]
  referralsMade      ReferralBonus[]          @relation("Referrer")
  referralsReceived  ReferralBonus[]          @relation("ReferredUser")
  meetingActionItems MeetingActionItem[]      @relation("ActionItemAssignee")

  // Phase 5: Learning & Appraisal
  appraisalDate         DateTime? // Initially joiningDate + 12 months, pushed if learning < 6h/month
  learningLogs          LearningLog[]
  learningVerifications LearningVerification[]
  learningAudits        LearningAudit[]

  // Daily Task Planner
  dailyTaskPlans DailyTaskPlan[]

  // MASH Chat System
  createdChannels        ChatChannel[]       @relation("ChannelCreator")
  channelMemberships     ChatChannelMember[]
  sentMessages           ChatMessage[]       @relation("MessageSender")
  sentDirectMessages     DirectMessage[]     @relation("DMSender")
  receivedDirectMessages DirectMessage[]     @relation("DMReceiver")

  // Tactical & Strategic Meetings
  tacticalMeetings TacticalMeeting[]

  // Daily Meeting (Huddle) - Mandatory
  dailyMeetings     DailyMeeting[]
  meetingCompliance MeetingCompliance[]
  aiExtractions     AIExtractionSession[]

  // Login tracking
  loginSessions LoginSession[]

  // Custom/Blended Roles
  customRoles UserCustomRole[]

  // WhatsApp Communication System
  whatsAppAccess        WhatsAppAccess[]
  assignedWhatsAppChats EmployeeWhatsAppChat[]

  // HR Hiring & Interviews
  conductedInterviews Interview[] @relation("InterviewConductor")
  assignedCandidates  Candidate[] @relation("CandidateManager")

  // Employee Onboarding Proposals
  employeeProposals        EmployeeProposal[] @relation("EmployeeProposalUser")
  createdEmployeeProposals EmployeeProposal[] @relation("EmployeeProposalCreator")

  // Client Feedback on Employee
  employeeClientFeedback EmployeeClientFeedback[]

  // Escalations & Appreciations
  escalationsReceived   EmployeeEscalation[]   @relation("EscalationEmployee")
  escalationsReported   EmployeeEscalation[]   @relation("EscalationReporter")
  appreciationsReceived EmployeeAppreciation[] @relation("AppreciationEmployee")
  appreciationsGiven    EmployeeAppreciation[] @relation("AppreciationGiver")

  // Manager Reviews
  managerReviewsReceived  ManagerBehaviorReview[] @relation("ManagerReviewSubject")
  managerReviewsConducted ManagerBehaviorReview[] @relation("ManagerReviewConductor")

  // Employer Branding
  brandingContentCreated  EmployerBrandingContent[] @relation("ContentCreator")
  brandingContentApproved EmployerBrandingContent[] @relation("ContentApprover")
  contentIdeas            ContentIdea[]

  // Engagement Activities
  activitiesOrganized EngagementActivity[] @relation("ActivityOrganizer")
  activitiesApproved  EngagementActivity[] @relation("ActivityApprover")

  // Work Anniversaries
  workAnniversaries WorkAnniversaryReminder[]

  // Day 0 Tasks
  day0Tasks       Day0Task[] @relation("Day0Employee")
  day0Assignments Day0Task[] @relation("Day0Assignee")

  // Unified Work Tracking & Google Drive
  googleDrive UserGoogleDrive?
  workEntries WorkEntry[]

  // WhatsApp Hub Enhancements
  whatsAppChatNotes   WhatsAppChatNote[]
  sharedWhatsAppChats SharedWhatsAppChat[]

  // Growth Score & Tactical Tracking
  socialMediaPosts       SocialMediaPost[]
  monthlyGrowthScores    MonthlyGrowthScore[]
  socialMediaPageMetrics SocialMediaPageMetrics[]
  clientCapacity         Int                      @default(10) // Number of clients expected to manage

  // Client Deliverables (Tactical Tracker)
  deliverablesCreated   ClientDeliverable[] @relation("DeliverableCreator")
  deliverablesSubmitted ClientDeliverable[] @relation("DeliverableSubmitter")
  deliverablesReviewed  ClientDeliverable[] @relation("DeliverableReviewer")

  // Recurring Expenses & Budget Management
  expensesCreated RecurringExpense[] @relation("ExpenseCreator")
  expensePayments ExpensePayment[]
  goalsOwned      Goal[]
  goalsCreated    Goal[]             @relation("GoalCreator")
  budgetAlerts    BudgetAlert[]

  // Device Requests
  deviceRequests DeviceRequest[]

  // Magic Link Authentication
  magicLinkTokens MagicLinkToken[]

  // Password Reset Tokens
  passwordResetTokens PasswordResetToken[]

  // Client Access Requests
  clientAccessRequests   ClientAccessRequest[] @relation("ClientAccessRequester")
  approvedAccessRequests ClientAccessRequest[] @relation("ClientAccessApprover")

  // Web Team Project Phases
  assignedWebPhases WebProjectPhase[]

  // Video Testimonials (Client Success Stories)
  requestedTestimonials VideoTestimonial[] @relation("TestimonialRequester")
  verifiedTestimonials  VideoTestimonial[] @relation("TestimonialVerifier")

  // Web Portal Page Feedback
  pageFeedback PageFeedback[]

  // Intern Profile
  internProfile InternProfile?

  // Freelancer Profile
  freelancerProfile FreelancerProfile?

  // Impersonation Sessions
  impersonationsAsAdmin  ImpersonationSession[] @relation("ImpersonationAdmin")
  impersonationsAsTarget ImpersonationSession[] @relation("ImpersonationTarget")

  // Attendance Import Batches
  attendanceImports AttendanceImport[]

  // Quotes
  quotesCreated Quote[] @relation("QuoteCreator")

  // SEO Module
  seoBacklinksCreated SeoBacklink[] @relation("BacklinkCreator")
  seoContentWritten   SeoContent[]  @relation("ContentWriter")
  seoTasksAssigned    SeoTask[]     @relation("SeoTaskAssignee")
  seoTasksReviewing   SeoTask[]     @relation("SeoTaskReviewer")

  // Ads Department
  assignedCampaigns Campaign[] @relation("CampaignAssignee")

  // Soft delete support (not yet enforced in API routes)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([department])
  @@index([status])
  @@index([joiningDate])
}

model Profile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ndaSigned          Boolean   @default(false) @map("nda_signed")
  ndaSignedAt        DateTime? @map("nda_signed_at")
  biometricPunch     Boolean   @default(false)
  razorpayLinked     Boolean   @default(false)
  profilePicture     String?
  panCard            String?
  aadhaar            String?
  linkedIn           String?
  favoriteFood       String?
  parentsPhone1      String?
  parentsPhone2      String?
  livingSituation    String?
  distanceFromOffice String?
  skills             String? // JSON array of skills
  bio                String?

  // Employee onboarding document URLs
  emergencyContactName  String?
  emergencyContactPhone String?
  panCardUrl            String?
  aadhaarUrl            String?
  bankDetailsUrl        String?
  educationCertUrl      String?

  // Policy acceptance tracking
  employeeHandbookAccepted      Boolean   @default(false)
  socialMediaPolicyAccepted     Boolean   @default(false)
  clientConfidentialityAccepted Boolean   @default(false)
  allPoliciesAccepted           Boolean   @default(false)
  policiesAcceptedAt            DateTime?
  completionPercentage          Int       @default(0)

  // Signature & KYC
  signatureData String? // Base64 signature image
  signatureType String? // 'draw' or 'type'
  signedAt      DateTime?
  selfieImage   String? // Webcam capture for KYC
  kycVerifiedAt DateTime?

  // Device Allocation
  allocatedDeviceType  String? // LAPTOP, DESKTOP, MOBILE, WHATSAPP_ONLY
  allocatedDeviceId    String? // Reference to Asset.id
  personalMobileNumber String? // For WhatsApp access
  officialPhoneNumber  String? // Allocated official number
  hasWhatsAppAccess    Boolean   @default(false)
  deviceAllocatedAt    DateTime?
}

// ============================================
// VIDEO TESTIMONIALS (Client Success Stories)
// ============================================

// Employee earns ₹1000 Amazon voucher for each video testimonial from client
// Badges displayed on profile linking to YouTube testimonials
model VideoTestimonial {
  id String @id @default(cuid())

  // Who requested the testimonial
  requestedById String
  requestedBy   User   @relation("TestimonialRequester", fields: [requestedById], references: [id])

  // Which client provided the testimonial
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Request details
  requestedAt        DateTime @default(now())
  requestMessage     String? // Message sent to client requesting testimonial
  clientContactName  String? // Who at the client gave the testimonial
  clientContactEmail String? // For follow-up

  // Testimonial content
  youtubeUrl   String? // The YouTube URL of the testimonial video
  thumbnailUrl String? // Custom thumbnail (or auto-extracted from YouTube)
  title        String? // Title/headline for the testimonial
  description  String? // Brief description or quote
  duration     Int? // Video duration in seconds

  // Status workflow: REQUESTED -> RECEIVED -> VERIFIED -> REWARDED
  status            String    @default("REQUESTED")
  receivedAt        DateTime? // When YouTube URL was added
  verifiedAt        DateTime? // When manager verified it's valid
  verifiedById      String?
  verifiedBy        User?     @relation("TestimonialVerifier", fields: [verifiedById], references: [id])
  verificationNotes String? // Notes from verification

  // Reward tracking
  voucherAmount Float     @default(1000) // ₹1000 Amazon voucher
  voucherCode   String? // Amazon voucher code issued
  rewardedAt    DateTime? // When reward was issued

  // Badge display
  badgeColor   String  @default("gold") // Badge color on profile
  isFeatured   Boolean @default(false) // Show prominently on profile
  displayOrder Int     @default(0) // Order in badge gallery

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestedById])
  @@index([clientId])
  @@index([status])
  @@index([verifiedById])
}

// ============================================
// CLIENT MANAGEMENT
// ============================================

model Client {
  id            String  @id @default(cuid())
  name          String
  logoUrl       String? // Company logo (external URL)
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  whatsapp      String?
  websiteUrl    String?
  address       String?
  gstNumber     String?
  panNumber     String?
  state         String?
  city          String?
  pincode       String?
  businessType  String? // B2B, B2C, D2C, B2B2C
  industry      String?
  monthlyBudget String?
  monthlyFee    Float? // Actual monthly fee amount
  tier          String  @default("STANDARD") // MICRO, STARTER, STANDARD, PREMIUM, ENTERPRISE
  clientSegment String  @default("INDIAN") // INDIAN, INTERNATIONAL, MYKOHI_WHITELABEL
  status        String  @default("ACTIVE") // ACTIVE, LOST, ON_HOLD, ONBOARDING

  // Client Type (for one-time vs recurring distinction)
  clientType      String  @default("RECURRING") // ONE_TIME, RECURRING
  isWebTeamClient Boolean @default(false) // Quick identifier for web team clients
  addedByUserId   String? // Track who added (for web team direct add)

  // Web Project Status (for past/current/future tracking)
  webProjectStatus    String? // PIPELINE, IN_PROGRESS, COMPLETED, MAINTENANCE
  webProjectStartDate DateTime? // When web project work started
  webProjectEndDate   DateTime? // When web project was completed
  webProjectNotes     String? // Notes specific to web project
  websiteType         String? // ECOMMERCE, CORPORATE, PORTFOLIO, LANDING, BLOG, CUSTOM
  techStack           String? // JSON array of technologies used

  // Parent-Child Client Hierarchy (e.g., MyKohi -> Upshaw, Karma, etc.)
  // WARNING: Application code must validate no circular references when setting parentClientId.
  parentClientId String?
  parentClient   Client?  @relation("ClientHierarchy", fields: [parentClientId], references: [id])
  subClients     Client[] @relation("ClientHierarchy")
  brandName      String? // Sub-brand name if different from main client name

  // Service & Billing Segmentation
  serviceSegment String @default("MARKETING") // MARKETING, WEBSITE, AI_TOOLS, AMC
  billingType    String @default("MONTHLY") // MONTHLY, QUARTERLY, ANNUAL, ONE_TIME
  billingAmount  Float? // Amount per billing cycle

  // Concerned Person (Account Handler)
  concernedPerson      String? // Name of person handling this account
  concernedPersonPhone String? // Contact number

  // Client Status Flags
  isLost          Boolean @default(false) // Lost client waiting for dues
  lostReason      String? // Reason for losing client
  stoppedServices Boolean @default(false) // Client asked to stop services
  upsellPotential String? // Potential for upselling (e.g., "MARKETING_PITCH")

  // Linked Client (for website + retainer same client)
  // WARNING: Application code must validate no circular references when setting linkedClientId.
  linkedClientId String?
  linkedClient   Client?  @relation("LinkedClients", fields: [linkedClientId], references: [id])
  linkedClients  Client[] @relation("LinkedClients")

  // Payment tracking
  paymentStatus        String  @default("PENDING")
  paymentDueDay        Int? // Day of month payment is due
  invoiceDayOfMonth    Int? // Day of month invoice is sent
  invoiceStatus        String? // SENT, PENDING, NOT_REQUIRED
  currentPaymentStatus String? // DONE, PENDING, PARTIAL, OVERDUE - current month status
  bankAccount          String?
  advanceAmount        Float?
  pendingAmount        Float?
  /// @deprecated Use selectedServices instead. JSON array of service names.
  services             String? // JSON array: ["SM", "SEO", "ADS", "WEB", "GMB"]

  // Payment Preferences (for Accounts Department)
  reminderFrequency String  @default("AS_PER_DUE_DATE") // NONE, WEEKLY, AS_PER_DUE_DATE
  paymentTerms      String  @default("NET_30") // IMMEDIATE, NET_15, NET_30, NET_45, CUSTOM
  customPaymentDays Int?
  preferredContact  String  @default("WHATSAPP") // WHATSAPP, EMAIL, CALL
  haltReminders     Boolean @default(false)
  accountsNotes     String?

  // Health Score (calculated fields)
  healthScore  Int? // 0-100
  healthStatus String? // HEALTHY, WARNING, AT_RISK

  // Project info
  projectStatus   String?
  projectPriority String?
  platform        String?
  startDate       DateTime?
  endDate         DateTime?
  progress        Int?

  // Client Onboarding (Post-Sale)
  onboardingToken         String?   @unique
  onboardingStatus        String    @default("PENDING") // PENDING, IN_PROGRESS, AWAITING_SLA, AWAITING_PAYMENT, COMPLETED
  slaSigned               Boolean   @default(false)
  slaSignedAt             DateTime?
  slaDocumentUrl          String?
  sowSigned               Boolean   @default(false)
  sowSignedAt             DateTime?
  sowDocumentUrl          String?
  initialPaymentConfirmed Boolean   @default(false)
  initialPaymentDate      DateTime?
  lifecycleStage          String    @default("LEAD") // LEAD, WON, ONBOARDING, ACTIVE, RETENTION, AT_RISK, CHURNED
  leadId                  String? // Back-reference to Lead

  // Entity routing (GST-based)
  entityType              String  @default("BRANDING_PIONEERS") // ATZ_MEDAPPZ, BRANDING_PIONEERS
  poNumber                String? // Purchase Order for enterprise clients
  welcomeMessageSent      Boolean @default(false)
  onboardingFormCompleted Boolean @default(false)

  // Account Manager - User who shared onboarding link
  accountManagerId   String?
  onboardingSharedBy String? // User ID who generated the onboarding link
  onboardingSharedAt DateTime? // When the link was shared

  // Proposal & Payment tracking
  proposalId         String? // Reference to ClientProposal
  paymentConfirmedAt DateTime?
  ledgerStartedAt    DateTime?

  // Client Portal mapping
  clientPortal ClientPortal?

  // Legacy onboarding fields
  primaryGoal    String?
  ndaSigned      Boolean @default(false)
  contractLength String?
  referralSource String?
  /// JSON object with business details and communication preferences (e.g. { "business": "...", "comms": "..." })
  notes          String?

  // Social media
  facebookUrl  String?
  instagramUrl String?
  linkedinUrl  String?
  twitterUrl   String?
  youtubeUrl   String?

  // Competitors
  competitor1 String?
  competitor2 String?
  competitor3 String?

  // JSON fields
  /// JSON object with audience demographics (e.g. { "ageRange": "25-45", "gender": "all", "location": "..." })
  targetAudience   String?
  brandAssets      String?
  /// JSON array of selected service objects; prefer this over the `services` field
  selectedServices String?
  contentTypes     String?

  // Credentials (encrypted/secure storage)
  credentials String? // JSON: website, analytics, ads, social logins

  // Relations
  accountability         AccountabilityCharter[]
  teamMembers            ClientTeamMember[]
  tasks                  Task[]
  meetings               Meeting[]
  contracts              Contract[]
  invoices               Invoice[]
  scopes                 ClientScope[]
  communicationLogs      CommunicationLog[]
  communicationSchedules CommunicationSchedule[]
  documents              Document[]
  reports                Report[]
  leads                  Lead[]
  lifecycleEvents        ClientLifecycleEvent[]
  clientUsers            ClientUser[]
  clientCredentials      ClientCredential[]
  supportTickets         SupportTicket[]

  // Forms & Onboarding
  rfpSubmissions RFPSubmission[]
  slaDocuments   SLADocument[]

  // Accountability
  workDeliverables WorkDeliverable[]
  achievements     Achievement[]

  // Daily Task Planner
  dailyTasks DailyTask[] @relation("DailyTaskClient")

  // Tactical Meeting KPIs
  properties           ClientProperty[]
  tacticalKPIEntries   TacticalKPIEntry[]
  aiExtractions        AIExtractionSession[]
  clientFeedback       ClientFeedback[]
  clientPortalFeedback ClientPortalFeedback[]

  // HR Relations - Escalations, Appreciations & Feedback
  employeeEscalations     EmployeeEscalation[]
  employeeAppreciations   EmployeeAppreciation[]
  employeeClientFeedbacks EmployeeClientFeedback[] @relation("EmployeeClientFeedback")

  // WhatsApp Groups & Operations Logs
  whatsAppGroups   ClientWhatsAppGroup[]
  operationsLogs   ClientOperationsLog[]
  whatsAppMessages WhatsAppMessage[]

  // Payments
  paymentCollections PaymentCollection[]
  paymentFollowUps   PaymentFollowUp[]
  ledgerEntries      ClientLedger[]

  // Bank Statement & Auto-Invoice
  bankTransactions  BankTransaction[]
  autoInvoiceConfig AutoInvoiceConfig?

  // Unified Work Tracking
  workEntries WorkEntry[]

  // WhatsApp Hub - Shared Chats
  sharedWhatsAppChats SharedWhatsAppChat[]

  // Growth Score & Tactical Tracking
  socialMediaPosts       SocialMediaPost[]
  socialMediaPageMetrics SocialMediaPageMetrics[]
  deliverables           ClientDeliverable[]

  // Recurring Expenses & Budget Management
  expenseAllocations ExpenseAllocation[]
  budgetAlerts       BudgetAlert[]

  // Platform Integrations (Google, Meta, etc.)
  oauthConnections    ClientOAuthConnection[]
  oauthAccessRequests OAuthAccessRequest[]

  // Client Reporting System
  platformAccounts ClientPlatformAccount[]
  importBatches    DataImportBatch[]

  // Portal Enhancements
  portalNotifications PortalNotification[]
  portalDocuments     ClientDocument[]
  portalAnnouncements ClientAnnouncement[]
  portalGoals         ClientGoal[]
  contentApprovals    ContentApproval[]
  userInvitations     ClientUserInvitation[]

  // Client Access Request & Web Team
  accessRequests       ClientAccessRequest[]
  webProjectPhases     WebProjectPhase[]
  maintenanceContracts MaintenanceContract[]

  // Web Portal
  sitemapPages   WebsiteSitemap[]
  webOnboardings WebOnboarding[]

  // Video Testimonials
  videoTestimonials VideoTestimonial[]

  // Quarterly Goals (internal employee goals linked to this client)
  goals Goal[]

  // Onboarding Checklist
  clientOnboardingChecklist ClientOnboardingChecklist?

  // Service Termination
  terminations      ServiceTermination[]
  terminationStatus String? // NONE, IN_NOTICE, TERMINATED

  // Automations & Expenses
  automations Automation[] @relation("AutomationClient")
  expenses    Expense[]    @relation("ExpenseClient")

  // Web Team Infrastructure
  domains             Domain[]
  hostingAccounts     HostingAccount[]
  webReimbursements   WebReimbursement[]
  upsellOpportunities UpsellOpportunity[]
  webProjects         WebProject[]

  // SEO Module
  seoKeywords  SeoKeyword[]  @relation("SeoKeywords")
  seoBacklinks SeoBacklink[] @relation("SeoBacklinks")
  seoContent   SeoContent[]  @relation("SeoContent")
  gbpProfiles  GbpProfile[]  @relation("GbpProfiles")
  seoTasks     SeoTask[]     @relation("SeoTasks")

  // Ads Department
  campaigns         Campaign[]         @relation("ClientCampaigns")
  budgetAllocations BudgetAllocation[] @relation("ClientBudgets")

  // Soft delete support (not yet enforced in API routes)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([tier])
  @@index([clientSegment])
  @@index([entityType])
  @@index([lifecycleStage])
  @@index([paymentStatus])
  @@index([onboardingStatus])
  @@index([parentClientId])
  @@index([clientType])
  @@index([isWebTeamClient])
  @@index([webProjectStatus])
  @@index([terminationStatus])
  @@index([deletedAt])
}

model ClientTeamMember {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String // ACCOUNT_MANAGER, SEO_SPECIALIST, ADS_SPECIALIST, SOCIAL_MANAGER, AUTOMATION_ENGINEER
  isPrimary  Boolean  @default(false)
  assignedAt DateTime @default(now())

  @@unique([clientId, userId])
  @@index([clientId])
  @@index([userId])
  @@index([role])
}

model ClientScope {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category  String // SEO, ADS, SOCIAL, WEB, AUTOMATION
  item      String // blogs, posts, reels, etc.
  quantity  Int // target quantity
  delivered Int      @default(0)
  month     DateTime
  status    String   @default("ON_TRACK") // ON_TRACK, OVER_DELIVERY, UNDER_DELIVERY

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([clientId, category])
  @@index([clientId, month])
  @@index([status])
}

// Client Deliverable - Individual work items for tactical tracking
model ClientDeliverable {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Work item details
  category    String // SOCIAL, YOUTUBE, SEO, GBP, ADS, WEB, DESIGN, VIDEO
  workItem    String // Name of the deliverable
  description String?

  // Monthly tracking with proof and KPIs
  month    String // Format: "2025-01" for January 2025
  proofUrl String? // Link to proof (drive, sheet, etc.)
  kpi      String? // KPI value or metric

  // Approval workflow
  status        String    @default("PENDING") // PENDING, SUBMITTED, APPROVED, REVISION_REQUIRED
  submittedAt   DateTime?
  submittedById String?
  submittedBy   User?     @relation("DeliverableSubmitter", fields: [submittedById], references: [id])
  reviewedAt    DateTime?
  reviewedById  String?
  reviewedBy    User?     @relation("DeliverableReviewer", fields: [reviewedById], references: [id])
  reviewNotes   String?

  // Client visibility
  clientVisible Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("DeliverableCreator", fields: [createdById], references: [id])

  @@index([clientId])
  @@index([clientId, month])
  @@index([category])
  @@index([status])
  @@index([submittedById])
}

// ============================================
// TASK & PROJECT MANAGEMENT
// ============================================

model Task {
  id          String  @id @default(cuid())
  title       String
  description String?
  department  String
  priority    String  @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String  @default("TODO") // TODO, IN_PROGRESS, REVIEW, REVISION, COMPLETED, CANCELLED
  type        String  @default("TASK") // TASK, RECURRING, SUBTASK

  // Dates
  dueDate     DateTime?
  startDate   DateTime?
  completedAt DateTime?

  // Assignment
  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creatorId  String
  creator    User    @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  reviewerId String?
  reviewer   User?   @relation("TaskReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  // Client relation (optional)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // QA Review
  qaStatus     String? // PENDING_REVIEW, APPROVED, REVISION_REQUIRED
  qaComments   String?
  qaReviewedAt DateTime?

  // Recurring task settings
  isRecurring  Boolean @default(false)
  recurrence   String? // DAILY, WEEKLY, MONTHLY
  parentTaskId String?

  // Attachments (JSON array of URLs)
  attachments String?

  // Time tracking & Outcome logic
  estimatedHours  Float?
  actualHours     Float?
  timeSpent       Int       @default(0) // time spent in minutes
  timerStartedAt  DateTime?
  taskOutcome     String    @default("PENDING") // PENDING, BREAKTHROUGH, BREAKDOWN
  breakdownReason String?
  proofUrl        String?

  // Relations
  comments    TaskComment[]
  subtasks    Subtask[]
  timeEntries TimeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Performance indexes
  @@index([assigneeId])
  @@index([creatorId])
  @@index([clientId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([department])
  @@index([assigneeId, status])
  @@index([clientId, status])
}

model TaskComment {
  id       String  @id @default(cuid())
  taskId   String
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content  String
  type     String  @default("COMMENT") // COMMENT, STATUS_CHANGE, ASSIGNMENT, SYSTEM
  metadata String? // JSON for additional data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model Subtask {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  completedBy String?
  order       Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hours       Float
  description String?
  date        DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([taskId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     String // TASK, MEETING, PAYMENT, REPORT, LEAVE, GENERAL
  title    String
  message  String
  link     String? // URL to navigate to
  isRead   Boolean @default(false)
  priority String  @default("NORMAL") // LOW, NORMAL, HIGH, URGENT

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

// ============================================
// MEETINGS
// ============================================

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String // CLIENT_CALL, INTERNAL, REVIEW, TRAINING
  category    String   @default("GENERAL") // STRATEGIC, TACTICAL, OPERATIONS, HUDDLE, GENERAL
  date        DateTime
  duration    Int? // in minutes
  location    String? // Physical location or meeting link
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  recurrence  String? // DAILY, WEEKLY, MONTHLY, QUARTERLY

  // Meeting notes & agenda
  agenda         String? // JSON array of agenda items
  notes          String?
  actionItems    String? // JSON array (legacy)
  minutesSummary String? // Markdown meeting minutes

  // MoM (Minutes of Meeting) for client meetings
  noteTakerUrl String? // Noota/MeetGeek URL for AI note-taking
  keyPointers  String? // Manual key points for physical meetings
  meetingLink  String? // Video call link (Google Meet, Zoom, etc.)

  participants       MeetingParticipant[]
  meetingActionItems MeetingActionItem[]

  isOnline    Boolean @default(true)
  momRecorded Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([date])
  @@index([status])
  @@index([type])
  @@index([clientId, date])
}

model MeetingParticipant {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String  @default("ATTENDEE") // ORGANIZER, ATTENDEE
  attended  Boolean @default(false)

  @@unique([meetingId, userId])
  @@index([userId])
}

// ============================================
// KNOWLEDGE BASE & SOP
// ============================================

model SOPCategory {
  id          String  @id @default(cuid())
  name        String // SEO, ADS, SOCIAL, AUTOMATION, HR
  description String?
  icon        String?
  order       Int     @default(0)
  sops        SOP[]

  createdAt DateTime @default(now())
}

model SOP {
  id         String      @id @default(cuid())
  categoryId String
  category   SOPCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title      String
  content    String // Markdown content
  version    String      @default("1.0")
  status     String      @default("ACTIVE") // ACTIVE, DRAFT, ARCHIVED
  department String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// TRAINING & CERTIFICATION
// ============================================

model Training {
  id          String  @id @default(cuid())
  title       String
  description String?
  department  String?
  type        String // COURSE, WORKSHOP, CERTIFICATION
  duration    Int? // in hours
  content     String? // JSON: modules, videos, quizzes
  isRequired  Boolean @default(false)

  userTrainings UserTraining[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserTraining {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingId  String
  training    Training  @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  progress    Int       @default(0) // 0-100
  status      String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  startedAt   DateTime?
  completedAt DateTime?
  score       Float?

  @@unique([userId, trainingId])
}

model Certification {
  id          String  @id @default(cuid())
  name        String
  description String?
  provider    String? // Internal, Google, Meta, etc.
  validFor    Int? // months until expiry

  userCertifications UserCertification[]
}

model UserCertification {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificationId String
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  earnedAt        DateTime      @default(now())
  expiresAt       DateTime?
  certificateUrl  String?

  @@unique([userId, certificationId])
}

// ============================================
// COMMUNICATION CHARTER & LOGS
// ============================================

// Communication templates for consistent client messaging
model CommunicationTemplate {
  id        String  @id @default(cuid())
  name      String
  category  String // ONBOARDING, WEEKLY_UPDATE, MONTHLY_REPORT, REVIEW_REQUEST, PAYMENT_REMINDER, ESCALATION
  type      String // EMAIL, CALL, WHATSAPP, MEETING
  subject   String?
  content   String // Template content with {{variables}}
  variables String? // JSON array of variable names
  isActive  Boolean @default(true)

  schedules CommunicationSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Scheduled communications per client - the "Charter"
model CommunicationSchedule {
  id         String                 @id @default(cuid())
  clientId   String
  client     Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  templateId String?
  template   CommunicationTemplate? @relation(fields: [templateId], references: [id])

  // Schedule definition
  name          String
  type          String // EMAIL, CALL, WHATSAPP, MEETING
  frequency     String // DAILY, WEEKLY, BI_WEEKLY, MONTHLY, QUARTERLY, ONE_TIME
  dayOfWeek     Int? // 0-6 for weekly schedules
  dayOfMonth    Int? // 1-31 for monthly schedules
  preferredTime String? // HH:MM format
  description   String?

  // Tracking
  lastSentAt     DateTime?
  nextDueAt      DateTime?
  missedCount    Int       @default(0)
  completedCount Int       @default(0)

  // Responsibility
  assignedToId String?
  status       String  @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED

  logs CommunicationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunicationLog {
  id       String  @id @default(cuid())
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Link to schedule if from charter
  scheduleId String?
  schedule   CommunicationSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  type        String // EMAIL, CALL, WHATSAPP, MEETING
  subject     String?
  content     String
  status      String? // SENT, DELIVERED, READ, FAILED
  sentAt      DateTime? // When the message was sent
  outcome     String? // SUCCESSFUL, NO_RESPONSE, RESCHEDULED, ESCALATED
  duration    Int? // Duration in minutes for calls/meetings
  actionItems String? // JSON array
  attachments String? // JSON array of URLs

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
}

// ============================================
// DOCUMENTS & FILE VAULT
// ============================================

model Document {
  id       String  @id @default(cuid())
  name     String
  type     String // CONTRACT, REPORT, ASSET, BRAND, INVOICE
  category String? // Branding, Ads Creatives, Reports, Contracts, Assets
  fileUrl  String
  fileSize Int?
  mimeType String?

  clientId     String?
  client       Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  uploadedById String
  uploadedBy   User    @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
}

// ============================================
// CONTRACTS
// ============================================

model Contract {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  type        String // SERVICE, NDA, RETAINER
  title       String
  startDate   DateTime
  endDate     DateTime
  renewalDate DateTime?
  value       Float?
  status      String    @default("ACTIVE") // ACTIVE, EXPIRED, RENEWED, CANCELLED
  terms       String? // JSON: payment terms, services included
  documentUrl String?

  // Digital signatures
  signerName      String?
  signerSignature String? // Base64 signature image
  agencySignature String? // Base64 signature image
  signedAt        DateTime?
  contractSubType String? // MASTER_SLA, SOW, VENDOR_NDA, EMPLOYMENT

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// FINANCE & INVOICING
// ============================================

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  amount        Float
  tax           Float     @default(0)
  total         Float
  paidAmount    Float     @default(0) // Track partial payments
  status        String    @default("DRAFT") // DRAFT, SENT, PARTIAL, PAID, OVERDUE, CANCELLED
  dueDate       DateTime
  paidAt        DateTime?
  items         String? // JSON array of line items
  notes         String?

  // Entity & type
  entityType    String    @default("BRANDING_PIONEERS") // ATZ_MEDAPPZ, BRANDING_PIONEERS
  isAdvance     Boolean   @default(false)
  currency      String    @default("INR") // INR, USD
  serviceMonth  DateTime?
  slaDocumentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments         PaymentCollection[]
  bankTransactions BankTransaction[]

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@index([entityType])
}

// Payment Collection - Tracks actual payments received with full details
model PaymentCollection {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  // Amount Details
  grossAmount   Float // Total amount before deductions
  tdsDeducted   Float @default(0) // TDS deducted by client (usually 10%)
  tdsPercentage Float @default(10) // TDS percentage (10%, 2%, etc.)
  gstAmount     Float @default(0) // GST amount (18%)
  netAmount     Float // Amount actually received (gross - TDS)

  // Collection Details
  collectedAt    DateTime @default(now()) // When payment was received
  collectedBy    String? // User ID who recorded the payment
  paymentMethod  String // NEFT, RTGS, UPI, CHEQUE, CASH, ONLINE
  transactionRef String? // UTR number, cheque number, etc.

  // Bank Account
  bankAccountId String? // Reference to EntityBankAccount
  bankName      String? // HDFC, AXIS, KOTAK, etc.
  accountNumber String? // Last 4 digits for reference

  // Retainer/Service Details
  retainerMonth DateTime? // Which month's retainer this is for
  serviceType   String? // RETAINER, PROJECT, ADVANCE, ADHOC
  description   String? // Additional description

  // Entity
  entityType String @default("BRANDING_PIONEERS") // ATZ_MEDAPPZ, BRANDING_PIONEERS
  currency   String @default("INR")

  // Status
  status String  @default("CONFIRMED") // PENDING, CONFIRMED, BOUNCED, REFUNDED
  notes  String?

  // Bank Statement matching
  bankTransactions BankTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([collectedAt])
  @@index([retainerMonth])
}

// Daily payment follow-up conversation log
model PaymentFollowUp {
  id             String    @id @default(cuid())
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  date           DateTime // The date of follow-up
  status         String // DONE, PENDING, REMIND, IN_PROCESS, CALL_NOT_PICKED, WILL_PAY, PAYMENT_RECEIVED
  notes          String? // Conversation notes
  nextAction     String? // What to do next
  nextActionDate DateTime? // When to follow up next
  recordedBy     String? // User ID who recorded this
  month          String? // Month being followed up for (e.g., "March 2026")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, date])
  @@index([clientId])
  @@index([date])
}

model Expense {
  id          String   @id @default(cuid())
  category    String // TOOLS, SOFTWARE, ADS, SALARY, OFFICE, OTHER
  description String
  amount      Float
  date        DateTime
  vendor      String? // Vendor name
  notes       String? // Additional notes
  clientId    String? // If expense is client-specific
  client      Client?  @relation("ExpenseClient", fields: [clientId], references: [id], onDelete: SetNull)
  receipt     String? // URL to receipt
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  submittedBy String? // User ID who submitted this expense
  approvedBy  String? // User ID who approved/rejected this expense

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// SALES CRM & LEADS
// ============================================

model Lead {
  id           String  @id @default(cuid())
  companyName  String
  contactName  String
  contactEmail String?
  contactPhone String?
  source       String // WEBSITE, REFERRAL, LINKEDIN, COLD_CALL, EVENT, RFP
  value        Float? // Potential deal value
  notes        String?

  // Sales Pipeline Stage (consolidated from status/stage/newStage)
  stage      String    @default("LEAD_RECEIVED") // LEAD_RECEIVED, RFP_SENT, RFP_COMPLETED, PROPOSAL_SHARED, FOLLOW_UP_ONGOING, MEETING_SCHEDULED, PROPOSAL_DISCUSSION, WON, LOST
  pipeline   String? // BRANDING_PIONEERS, BRAINMINDS
  lostReason String?
  wonAt      DateTime?

  // Lead Classification
  leadCategory     String? // DOCTOR, CLINIC, HOSPITAL, HEALTHCARE_STARTUP, NON_HEALTHCARE
  leadPriority     String  @default("WARM") // HOT, WARM, COLD
  location         String? // City
  state            String?
  yearsInOperation String? // 0-1, 1-3, 3-5, 5+

  // RFP Tracking
  rfpToken       String?   @unique
  rfpStatus      String?   @default("PENDING") // PENDING, SENT, COMPLETED
  rfpSentAt      DateTime?
  rfpCompletedAt DateTime?
  rfpResponses   String? // JSON object with all RFP answers

  // Healthcare-specific fields
  isHealthcare      Boolean @default(false)
  healthcareType    String? // CLINIC, HOSPITAL, DOCTOR, LAB
  patientVolume     String? // Daily patient volume range
  specialization    String? // Medical specialty
  numberOfLocations Int?

  // Additional RFP fields
  primaryObjective  String? // Main goal from RFP
  currentChallenges String? // JSON array of challenges
  businessType      String? // Industry/business type
  pastMarketing     String? // JSON array of past marketing efforts
  workedWithAgency  Boolean @default(false)
  agencyIssues      String? // What went wrong with previous agency
  timeline          String? // ASAP, 1-3_MONTHS, 3-6_MONTHS, EXPLORING
  budgetRange       String? // UNDER_25K, 25K-50K, 50K-1L, 1L-2.5L, ABOVE_2.5L

  // Client link when won
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Follow-up tracking
  nextFollowUp    DateTime?
  lastContactedAt DateTime?
  followUpNotes   String? // JSON array
  callNotes       String? // JSON array

  assignedToId      String?
  assignedTo        User?                  @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy         String? // User ID who created this lead
  proposals         Proposal[]
  activities        LeadActivity[]
  reminders         FollowUpReminder[]
  nurturingActions  LeadNurturingAction[]
  handovers         SalesHandover[]
  meetings          SalesMeeting[]
  whatsappMessages  SalesWhatsAppMessage[]
  deals             SalesDeal[]
  dailyTasks        SalesDailyTask[]
  dailyPlannerTasks DailyTask[]            @relation("DailyTaskLead")

  // Soft delete support (not yet enforced in API routes)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([stage])
  @@index([pipeline])
  @@index([leadPriority])
  @@index([assignedToId])
  @@index([isHealthcare])
  @@index([rfpStatus])
  @@index([createdAt])
  @@index([assignedToId, stage])
  @@index([deletedAt])
}

model Proposal {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title       String
  value       Float
  services    String? // JSON array of services
  validUntil  DateTime
  status      String   @default("DRAFT") // DRAFT, SENT, VIEWED, ACCEPTED, REJECTED
  documentUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// HR & HIRING
// ============================================

model Candidate {
  id           String  @id @default(cuid())
  name         String
  email        String
  phone        String?
  position     String
  department   String
  resumeUrl    String?
  portfolioUrl String?
  linkedInUrl  String?
  source       String? // LINKEDIN, REFERRAL, JOB_BOARD, DIRECT, CAREERS_PAGE, NAUKRI, INDEED
  referredBy   String? // Employee ID if referral

  // Pipeline Status
  status       String @default("APPLICATION") // APPLICATION, SCREENING, PHONE_SCREEN, MANAGER_INTERVIEW, TEST_TASK, FOUNDER_INTERVIEW, OFFER, JOINED, REJECTED, ON_HOLD
  currentStage String @default("APPLIED") // APPLIED, PHONE_SCREEN_SCHEDULED, PHONE_SCREEN_DONE, MANAGER_INTERVIEW_SCHEDULED, MANAGER_INTERVIEW_DONE, TEST_TASK_ASSIGNED, TEST_TASK_SUBMITTED, FOUNDER_INTERVIEW_SCHEDULED, FOUNDER_INTERVIEW_DONE, OFFER_PENDING, OFFER_SENT, OFFER_ACCEPTED, JOINED, REJECTED

  // Manager Assignment
  assignedManagerId String?
  assignedManager   User?   @relation("CandidateManager", fields: [assignedManagerId], references: [id])

  // Salary & Experience
  expectedSalary Float?
  offeredSalary  Float?
  experience     Int? // Years of experience
  noticePeriod   Int? // Days

  // Interview Feedback
  phoneScreenNotes  String?
  phoneScreenRating Int? // 1-5
  managerFeedback   String?
  managerRating     Int? // 1-5
  founderFeedback   String?
  founderDecision   String? // APPROVED, REJECTED, HOLD
  interviewFeedback String? // JSON array of all feedback

  // Test Task
  testTaskUrl      String?
  testTaskScore    Float?
  testTaskFeedback String?

  // HR Notes
  notes           String?
  rejectionReason String?

  // Relations
  interviews  Interview[]
  offerLetter OfferLetter?
  assessment  CandidateAssessment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([assignedManagerId])
}

model CandidateAssessment {
  id          String    @id @default(cuid())
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Token for public access
  token     String  @unique @default(cuid())
  completed Boolean @default(false)

  // Personal & Contact
  fullName     String?
  email        String?
  phone        String?
  currentCity  String?
  dateOfBirth  String?
  linkedInUrl  String?
  portfolioUrl String?
  resumeUrl    String?

  // Professional Background
  totalExperience  Float? // years
  currentCompany   String?
  currentRole      String?
  currentSalary    Float?
  expectedSalary   Float?
  noticePeriod     String? // immediate, 15days, 30days, 60days, 90days
  reasonForLeaving String?

  // Skills & Expertise
  primarySkills  String? // JSON array
  tools          String? // JSON array (tools/software they use)
  certifications String? // text
  languagesKnown String? // JSON array

  // Role Fit
  canWorkFromOffice Boolean? // Can join office at Sector 32, Gurgaon
  commuteDetails    String? // How will they commute / current location distance
  joiningTimeline   String? // immediate, 1week, 2weeks, 1month, negotiable
  readyForTrial     Boolean? // Ready for 1-week paid trial
  trialAvailability String? // When can they start trial

  // Healthcare Experience
  hasHealthcareExp  Boolean?
  healthcareDetails String? // Detailed project descriptions
  healthcareClients String? // List of healthcare clients/brands

  // Work Samples & Portfolio
  workSampleUrls String? // JSON array of URLs
  caseStudyUrl   String?
  githubUrl      String?

  // Screening Questions
  whyThisRole        String? // Why interested in this role
  biggestAchievement String? // Career highlight
  challengeExample   String? // How they handled a difficult situation
  teamWorkStyle      String? // solo, collaborative, both
  learningApproach   String? // How they stay updated
  salaryNegotiable   Boolean? // Is salary negotiable
  availableForCalls  Boolean? // Available for phone screening
  preferredCallTime  String? // Morning, Afternoon, Evening

  // Self Assessment
  relevanceRating  Int? // 1-10 how relevant they feel for this role
  strengthAreas    String? // JSON array
  improvementAreas String? // JSON array

  // Additional
  referenceContacts String? // JSON array of {name, company, phone, relation}
  additionalInfo    String?
  questionsForUs    String? // Questions candidate has for us

  // HR Pipeline Tracking
  hrStatus      String    @default("PENDING_REVIEW") // PENDING_REVIEW, SHORTLISTED, REJECTED, INTERVIEW_SCHEDULED, TASK_ASSIGNED, TASK_SUBMITTED, FINAL_ROUND, SELECTED, ON_HOLD
  hrNotes       String?
  shortlistedAt DateTime?
  shortlistedBy String?

  // Interview Tracking
  interviewDate   DateTime?
  interviewMode   String? // OFFICE, VIDEO_CALL, PHONE
  interviewNotes  String?
  interviewRating Int? // 1-5

  // Task Assignment
  taskTitle         String?
  taskDescription   String?
  taskDeadline      DateTime?
  taskAssignedAt    DateTime?
  taskSubmissionUrl String?
  taskSubmittedAt   DateTime?
  taskScore         Float?
  taskFeedback      String?

  // Final Round
  finalRoundDate     DateTime?
  finalRoundNotes    String?
  finalRoundDecision String? // SELECTED, REJECTED, ON_HOLD
  finalDecisionBy    String?
  finalDecisionAt    DateTime?

  // Offer
  offerSalary   Float?
  offerDate     DateTime?
  offerAccepted Boolean?
  joiningDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([hrStatus])
  @@index([candidateId])
}

// ============================================
// EMPLOYEE ONBOARDING PROPOSAL (Token-based wizard)
// ============================================

model EmployeeProposal {
  id    String @id @default(cuid())
  token String @unique @default(cuid())

  // Pre-filled by HR
  candidateName   String
  candidateEmail  String
  candidatePhone  String
  department      String
  position        String
  employmentType  String   @default("FULL_TIME") // FULL_TIME, PART_TIME, INTERN, FREELANCER
  offeredSalary   Float
  joiningDate     DateTime
  probationMonths Int      @default(3)
  entityType      String   @default("BRANDING_PIONEERS")

  // Step 1: Confirm Personal Details
  confirmedName      String?
  dateOfBirth        DateTime?
  bloodGroup         String?
  personalPhone      String?
  personalEmail      String?
  currentAddress     String?
  city               String?
  state              String?
  pincode            String?
  parentsAddress     String?
  fatherPhone        String?
  motherPhone        String?
  emergencyName      String?
  emergencyPhone     String?
  emergencyRelation  String?
  linkedinUrl        String?
  languages          String?
  livingSituation    String?
  distanceFromOffice String?
  favoriteFood       String?
  healthConditions   String?
  detailsConfirmedAt DateTime?

  // Step 2: NDA Signing
  ndaAccepted      Boolean   @default(false)
  ndaAcceptedAt    DateTime?
  ndaSignerName    String?
  ndaSignatureData String? // base64 drawn or typed name
  ndaSignatureType String? // 'type' or 'draw'

  // Step 3: Bond Agreement Signing
  bondAccepted       Boolean   @default(false)
  bondAcceptedAt     DateTime?
  bondSignerName     String?
  bondSignatureData  String?
  bondSignatureType  String?
  bondDurationMonths Int       @default(12)

  // Step 4: Company Policies Acknowledgment
  handbookAccepted          Boolean   @default(false)
  socialMediaPolicyAccepted Boolean   @default(false)
  confidentialityAccepted   Boolean   @default(false)
  antiHarassmentAccepted    Boolean   @default(false)
  codeOfConductAccepted     Boolean   @default(false)
  policiesAcceptedAt        DateTime?
  policiesSignerName        String?
  policiesSignatureData     String?
  policiesSignatureType     String?

  // Step 5: Document Submission
  profilePictureUrl    String?
  panCardUrl           String?
  aadhaarUrl           String?
  educationCertUrl     String?
  bankAccountName      String?
  bankName             String?
  bankAccountNumber    String?
  bankIfscCode         String?
  documentsSubmittedAt DateTime?

  // Step 6: Welcome Complete
  onboardingCompleted   Boolean   @default(false)
  onboardingCompletedAt DateTime?
  magicLinkSent         Boolean   @default(false)
  magicLinkSentAt       DateTime?

  // Workflow
  currentStep Int       @default(1)
  status      String    @default("SENT") // SENT, VIEWED, DETAILS_CONFIRMED, NDA_SIGNED, BOND_SIGNED, POLICIES_ACCEPTED, DOCS_SUBMITTED, COMPLETED, ACTIVATED
  expiresAt   DateTime
  viewedAt    DateTime?

  // Links
  userId      String? // Created after onboarding completes
  user        User?   @relation("EmployeeProposalUser", fields: [userId], references: [id])
  createdById String
  createdBy   User    @relation("EmployeeProposalCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([status])
  @@index([userId])
}

model LeaveRequest {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  type       String // ANNUAL, SICK, CASUAL, UNPAID, WFH
  startDate  DateTime
  endDate    DateTime
