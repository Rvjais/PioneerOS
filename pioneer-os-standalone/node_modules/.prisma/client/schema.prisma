// ============================================
// COMPANY ENTITIES & BANKING
// ============================================

model CompanyEntity {
  id        String  @id @default(cuid())
  code      String  @unique // ATZ_MEDAPPZ, BRANDING_PIONEERS, RAIN_MINDZ, RAIN_AI_LLC
  name      String // Full legal name
  tradeName String? // Trading name if different
  type      String  @default("PVT_LTD") // PVT_LTD, LLC, LLP, PROPRIETORSHIP
  country   String  @default("IN") // IN, US, UK

  // Registration Details
  gstNumber String?
  panNumber String?
  cinNumber String? // Company Identification Number (India)
  einNumber String? // Employer Identification Number (US)
  tanNumber String? // Tax Deduction Account Number

  // Address
  registeredAddress String?
  operatingAddress  String?
  city              String?
  state             String?
  pincode           String?

  // Contact
  email   String?
  phone   String?
  website String?

  // Invoicing
  invoicePrefix   String? // e.g., "BP", "ATZ", "RM"
  invoiceCounter  Int     @default(0)
  defaultCurrency String  @default("INR")

  // Logo & Branding
  logoUrl       String?
  letterheadUrl String?
  signatureUrl  String?

  // Status
  isActive  Boolean @default(true)
  isPrimary Boolean @default(false) // Primary billing entity

  // Relations
  bankAccounts    EntityBankAccount[]
  paymentGateways EntityPaymentGateway[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_entities")
}

model EntityBankAccount {
  id       String        @id @default(cuid())
  entityId String
  entity   CompanyEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)

  bankName      String // HDFC, AXIS, KOTAK, ICICI, etc.
  accountName   String // Account holder name
  accountNumber String
  ifscCode      String? // For Indian banks
  swiftCode     String? // For international transfers
  routingNumber String? // For US banks
  branchName    String?
  branchAddress String?

  accountType String @default("CURRENT") // CURRENT, SAVINGS, ESCROW
  currency    String @default("INR")

  // Display
  displayName String? // e.g., "HDFC Main", "Axis Salary"
  isPrimary   Boolean @default(false)
  isActive    Boolean @default(true)

  // For reconciliation
  lastBalance     Float?
  lastBalanceDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("entity_bank_accounts")
}

model EntityPaymentGateway {
  id       String        @id @default(cuid())
  entityId String
  entity   CompanyEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)

  provider    String // RAZORPAY, STRIPE, PAYPAL, PAYU, CASHFREE
  displayName String? // e.g., "Razorpay Main", "Stripe International"

  // Credentials (encrypted in production)
  merchantId    String?
  apiKeyId      String? // Public key / Key ID
  apiKeySecret  String? // Secret key (should be encrypted)
  webhookSecret String?

  // Configuration
  mode                String  @default("LIVE") // TEST, LIVE
  supportedCurrencies String? // JSON array: ["INR", "USD"]
  defaultCurrency     String  @default("INR")

  // Features
  supportsSubscription   Boolean @default(false)
  supportsRefund         Boolean @default(true)
  supportsPartialPayment Boolean @default(false)

  // Fee structure
  feePercentage Float? // e.g., 2.0 for 2%
  fixedFee      Float? // Fixed fee per transaction

  // Status
  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  // Tracking
  lastUsedAt        DateTime?
  totalTransactions Int       @default(0)
  totalVolume       Float     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("entity_payment_gateways")
}

// ============================================
// SELF-APPRAISAL SYSTEM
// ============================================

model SelfAppraisal {
  id          String @id @default(cuid())
  userId      String
  cycleYear   Int // e.g., 2024
  cyclePeriod String @default("ANNUAL") // ANNUAL, MID_YEAR

  // Status tracking
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, SUBMITTED, MANAGER_REVIEW, COMPLETED, SKIPPED
  triggeredAt DateTime  @default(now())
  startedAt   DateTime?
  submittedAt DateTime?
  completedAt DateTime?

  // Self-Assessment Sections
  // Section 1: Overall Performance
  overallRating      Int? // 1-5 self-rating
  keyAccomplishments String? // Text: major accomplishments this year
  challengesFaced    String? // Text: challenges and how overcame

  // Section 2: Goals Review
  goalsAchieved String? // JSON: [{goal, achievement, evidence}]
  goalsMissed   String? // JSON: [{goal, reason}]

  // Section 3: Skills & Development
  skillsImproved    String? // JSON: skills improved this year
  learningCompleted String? // JSON: courses, certifications
  skillsToImprove   String? // Text: areas for growth

  // Section 4: Role & Responsibilities
  roleClarity       Int? // 1-5: clarity on role
  resourcesAdequate Int? // 1-5: tools/resources provided
  workloadBalance   Int? // 1-5: work-life balance

  // Section 5: Team & Culture
  teamCollaboration Int? // 1-5: team collaboration
  managerSupport    Int? // 1-5: manager support
  cultureFit        Int? // 1-5: culture alignment

  // Section 6: Future Goals
  nextYearGoals     String? // JSON: goals for next year
  careerAspirations String? // Text: long-term career goals
  supportNeeded     String? // Text: support needed from company
  trainingRequests  String? // JSON: requested trainings

  // Section 7: Feedback
  companyFeedback String? // Text: feedback about company
  teamFeedback    String? // Text: feedback about team
  processFeedback String? // Text: suggestions for improvement

  // Manager Review
  managerComments String?
  managerRating   Int? // 1-5 manager rating
  reviewedBy      String? // Manager user ID
  reviewedAt      DateTime?

  // Final outcome
  finalRating             Int? // 1-5 agreed rating
  incrementRecommendation String? // NO_INCREMENT, STANDARD, ABOVE_STANDARD, EXCEPTIONAL
  promotionRecommendation Boolean @default(false)

  // Learning hours tracking
  learningHoursThisYear Float @default(0)
  learningHoursRequired Float @default(72) // 6 hours/month * 12 months

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, cycleYear, cyclePeriod])
  @@index([userId])
  @@index([status])
  @@map("self_appraisals")
}

// ============================================
// LOGIN SESSION TRACKING
// ============================================

model LoginSession {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userType String @default("EMPLOYEE") // EMPLOYEE, CLIENT

  // Device Information
  ipAddress      String?
  userAgent      String?
  deviceType     String? // DESKTOP, MOBILE, TABLET
  browser        String?
  browserVersion String?
  os             String?
  osVersion      String?

  // Location (from IP geolocation)
  country     String?
  countryCode String?
  region      String?
  city        String?
  latitude    Float?
  longitude   Float?
  timezone    String?
  isp         String?

  // Session details
  sessionToken   String?   @unique
  isActive       Boolean   @default(true)
  loginAt        DateTime  @default(now())
  logoutAt       DateTime?
  lastActivityAt DateTime  @default(now())
  expiresAt      DateTime?

  // Security flags
  isSuspicious      Boolean @default(false)
  suspiciousReason  String?
  isNewDevice       Boolean @default(false)
  deviceFingerprint String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([ipAddress])
  @@index([loginAt])
  @@map("login_sessions")
}

// ============================================
// MASH CHAT SYSTEM
// ============================================

model ChatChannel {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique // e.g., "general", "announcements", "mash"
  description String?
  type        String  @default("PUBLIC") // PUBLIC, PRIVATE, DIRECT, MASH
  icon        String? // Channel icon/emoji

  // For MASH channel - system announcements
  isMash     Boolean @default(false)
  isArchived Boolean @default(false)

  // Permissions
  allowedRoles String? // JSON array of roles that can post (null = everyone)
  isReadOnly   Boolean @default(false) // Only admins can post

  createdById String?
  createdBy   User?   @relation("ChannelCreator", fields: [createdById], references: [id], onDelete: SetNull)

  messages ChatMessage[]
  members  ChatChannelMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([type])
}

model ChatChannelMember {
  id        String      @id @default(cuid())
  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  role       String    @default("MEMBER") // OWNER, ADMIN, MEMBER
  isMuted    Boolean   @default(false)
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  @@unique([channelId, userId])
  @@index([userId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)

  content String
  type    String @default("TEXT") // TEXT, ANNOUNCEMENT, POLICY_UPDATE, SYSTEM, FILE

  // For MASH announcements
  priority String? // NORMAL, IMPORTANT, URGENT
  isPinned Boolean @default(false)

  // Attachments
  attachments String? // JSON array of file URLs

  // Reply/Thread
  parentId String?
  parent   ChatMessage?  @relation("MessageReplies", fields: [parentId], references: [id])
  replies  ChatMessage[] @relation("MessageReplies")

  // Reactions
  reactions String? // JSON: { "emoji": ["userId", ...] }

  // Edit tracking
  isEdited  Boolean   @default(false)
  editedAt  DateTime?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Read receipts
  readBy String? // JSON array of userIds who have read

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId, createdAt])
  @@index([senderId])
  @@index([isPinned])
}

model DirectMessage {
  id         String @id @default(cuid())
  senderId   String
  sender     User   @relation("DMSender", fields: [senderId], references: [id], onDelete: Restrict)
  receiverId String
  receiver   User   @relation("DMReceiver", fields: [receiverId], references: [id], onDelete: Restrict)

  content     String
  type        String  @default("TEXT") // TEXT, FILE
  attachments String? // JSON array of file URLs

  isRead    Boolean   @default(false)
  readAt    DateTime?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, isRead])
}

// ============================================
// TACTICAL & STRATEGIC MEETINGS
// ============================================

// Client properties (multiple GBPs, websites per client)
model ClientProperty {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type      String // GBP, WEBSITE, SOCIAL_PAGE
  name      String // "Main GBP", "Secondary GBP", "Main Website", etc.
  url       String? // URL or GBP ID
  isActive  Boolean  @default(true)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  kpiEntries TacticalKPIEntry[]

  @@index([clientId])
}

// Monthly tactical meeting submission
model TacticalMeeting {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month          DateTime // First day of the month this reports on (e.g., Dec 2025 data entered in Jan 2026)
  reportingMonth DateTime // Actual month being reported (previous month)

  // Submission tracking
  status          String    @default("DRAFT") // DRAFT, SUBMITTED, REVIEWED, APPROVED
  submittedAt     DateTime?
  submittedOnTime Boolean   @default(false) // Before 3rd of month
  reviewedBy      String?
  reviewedAt      DateTime?
  managerNotes    String?

  // Aggregated scores (calculated)
  performanceScore        Float? // Avg growth across all clients
  accountabilityScore     Float? // Projects managed vs expected
  clientSatisfactionScore Float? // NPS + feedback score
  overallScore            Float? // Weighted aggregate

  // KPI entries for this meeting
  kpiEntries TacticalKPIEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId, month])
  @@index([status])
}

// Individual KPI entries per client/property in tactical meeting
model TacticalKPIEntry {
  id         String          @id @default(cuid())
  meetingId  String
  meeting    TacticalMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  clientId   String
  client     Client          @relation(fields: [clientId], references: [id])
  propertyId String? // Optional link to specific GBP/site
  property   ClientProperty? @relation(fields: [propertyId], references: [id])

  // Department determines which KPIs are relevant
  department String // SEO, ADS, SOCIAL, WEB, etc.

  // SEO KPIs
  organicTraffic     Int? // Current month
  prevOrganicTraffic Int? // Previous month (for comparison)
  leads              Int?
  prevLeads          Int?
  gbpCalls           Int? // GBP phone calls
  prevGbpCalls       Int?
  gbpDirections      Int? // GBP direction requests
  prevGbpDirections  Int?
  keywordsTop3       Int? // Keywords in positions 1-3
  prevKeywordsTop3   Int?
  keywordsTop10      Int? // Keywords in positions 4-10
  prevKeywordsTop10  Int?
  keywordsTop20      Int? // Keywords in positions 11-20
  prevKeywordsTop20  Int?
  backlinksBuilt     Int?
  prevBacklinksBuilt Int?

  // ADS KPIs
  adSpend               Float?
  prevAdSpend           Float?
  impressions           Int?
  prevImpressions       Int?
  clicks                Int?
  prevClicks            Int?
  conversions           Int?
  prevConversions       Int?
  costPerConversion     Float?
  prevCostPerConversion Float?
  roas                  Float? // Return on ad spend
  prevRoas              Float?

  // SOCIAL KPIs
  followers          Int?
  prevFollowers      Int?
  engagement         Float? // Engagement rate %
  prevEngagement     Float?
  postsPublished     Int?
  prevPostsPublished Int?
  reachTotal         Int?
  prevReachTotal     Int?
  videoViews         Int?
  prevVideoViews     Int?

  // WEB KPIs
  pageSpeed              Int? // Score 0-100
  prevPageSpeed          Int?
  bounceRate             Float?
  prevBounceRate         Float?
  avgSessionDuration     Float? // In seconds
  prevAvgSessionDuration Float?
  pagesBuilt             Int?
  prevPagesBuilt         Int?
  bugsFixed              Int?
  prevBugsFixed          Int?

  // Generic metrics (JSON for flexible data)
  customMetrics String? // JSON for department-specific custom metrics

  // Auto-calculated growth percentages
  trafficGrowth  Float?
  leadsGrowth    Float?
  callsGrowth    Float?
  keywordsGrowth Float?

  // Notes
  notes         String? // General notes for this KPI entry
  achievements  String? // What went well
  challenges    String? // What was difficult
  nextMonthPlan String? // Plans for next month

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([clientId])
}

// Quarterly strategic meeting
model StrategicMeeting {
  id          String    @id @default(cuid())
  quarter     Int // 1, 2, 3, 4
  year        Int
  department  String? // Null for company-wide
  conductedAt DateTime?

  // Aggregated quarterly data
  quarterlyData String? // JSON: aggregated KPIs for the quarter

  // Goals and objectives
  goals       StrategicGoal[]
  peerReviews PeerReview[]

  // Meeting notes
  summary      String?
  keyDecisions String? // JSON array
  actionItems  String? // JSON array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quarter, year, department])
}

// Goals set in strategic meetings
model StrategicGoal {
  id         String           @id @default(cuid())
  meetingId  String
  meeting    StrategicMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId     String? // Individual goal
  department String? // Department goal
  clientId   String? // Client-specific goal

  title         String
  description   String?
  targetMetric  String? // e.g., "Increase traffic by 20%"
  targetValue   Float?
  currentValue  Float?
  deadline      DateTime?
  status        String    @default("PENDING") // PENDING, IN_PROGRESS, ACHIEVED, MISSED
  achievedValue Float?
  achievedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([userId])
}

// Peer reviews in strategic meetings
model PeerReview {
  id         String           @id @default(cuid())
  meetingId  String
  meeting    StrategicMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  reviewerId String // Who is giving the review
  revieweeId String // Who is being reviewed

  // Ratings (1-5 scale)
  collaborationRating Int?
  communicationRating Int?
  deliveryRating      Int?
  innovationRating    Int?
  overallRating       Int?

  // Feedback
  didWell             String? // What they did well
  needsImprovement    String? // What they didn't do well
  shouldDoDifferently String? // What they should do differently
  additionalComments  String?

  isAnonymous Boolean @default(false)
  isPublic    Boolean @default(true) // Visible to team

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, reviewerId, revieweeId])
  @@index([revieweeId])
}

// Employee scorecard (aggregated view of all scores)
model EmployeeScorecard {
  id     String   @id @default(cuid())
  userId String
  month  DateTime // Month this scorecard is for

  // Performance Score (growth of results)
  performanceScore     Float   @default(0)
  performanceBreakdown String? // JSON: detailed breakdown

  // Accountability Score (projects managed vs expected)
  accountabilityScore Float @default(0)
  projectsManaged     Int   @default(0)
  projectsExpected    Int   @default(0)

  // Client Satisfaction Score
  clientSatisfactionScore Float  @default(0)
  avgNpsScore             Float?
  positiveReviews         Int    @default(0)
  negativeReviews         Int    @default(0)
  escalationsCount        Int    @default(0)
  churnedClients          Int    @default(0)

  // Learning Goal Compliance
  learningHoursRequired  Float   @default(6)
  learningHoursCompleted Float   @default(0)
  learningCompliant      Boolean @default(false)
  appraisalDelayMonths   Int     @default(0) // Months delayed due to learning

  // Overall Score (weighted)
  overallScore   Float @default(0)
  companyRank    Int?
  departmentRank Int?

  // Appraisal eligibility
  isAppraisalEligible Boolean   @default(false)
  nextAppraisalDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId, month])
}

// Client NPS/Feedback tracking
model ClientFeedback {
  id       String   @id @default(cuid())
  clientId String
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month    DateTime

  // NPS Score
  npsScore    Int? // -100 to 100 scale (Promoter/Passive/Detractor)
  npsCategory String? // PROMOTER, PASSIVE, DETRACTOR

  // Satisfaction ratings
  overallSatisfaction Int? // 1-10
  communicationRating Int? // 1-10
  deliveryRating      Int? // 1-10
  valueRating         Int? // 1-10

  // Feedback text
  feedback     String?
  improvements String?

  // Escalations
  hadEscalation     Boolean @default(false)
  escalationDetails String?

  // Churn risk
  churnRisk        String? // LOW, MEDIUM, HIGH
  churnedThisMonth Boolean @default(false)
  churnReason      String?

  collectedAt DateTime @default(now())
  collectedBy String?

  @@unique([clientId, month])
  @@index([clientId])
}

// Client Portal Feedback - submitted via client portal
model ClientPortalFeedback {
  id           String     @id @default(cuid())
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientUserId String
  clientUser   ClientUser @relation(fields: [clientUserId], references: [id], onDelete: Cascade)

  type    String // GENERAL, SERVICE_QUALITY, DELIVERABLES, COMMUNICATION, SUGGESTION, ISSUE
  rating  Int // 1-5 stars
  message String
  status  String @default("PENDING") // PENDING, REVIEWED, RESOLVED

  // Response from team
  response    String?
  respondedBy String?
  respondedAt DateTime?

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([status])
}

// ============================================
// CUSTOM ROLES / BLENDED ROLES
// ============================================

model CustomRole {
  id              String           @id @default(cuid())
  name            String           @unique // e.g., "OM_HR_SOCIAL"
  displayName     String // e.g., "Operations Manager (HR + Social)"
  baseRoles       String // JSON: ["MANAGER", "HR"]
  departments     String // JSON: ["HR", "SOCIAL", "OPERATIONS"]
  permissions     String? // JSON: granular feature access
  isActive        Boolean          @default(true)
  userAssignments UserCustomRole[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model UserCustomRole {
  id           String     @id @default(cuid())
  userId       String
  customRoleId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole   CustomRole @relation(fields: [customRoleId], references: [id])
  assignedAt   DateTime   @default(now())

  @@unique([userId, customRoleId])
}

// ============================================
// CLIENT WHATSAPP GROUPS
// ============================================

model ClientWhatsAppGroup {
  id                    String   @id @default(cuid())
  clientId              String
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name                  String // "Main Communication", "Urgent Issues"
  groupType             String // MAIN, SUPPORT, URGENT, INTERNAL
  joinLink              String // https://chat.whatsapp.com/...
  qrCodeUrl             String?
  officialPhoneRequired String? // Phone number that must be used to join
  isActive              Boolean  @default(true)
  memberCount           Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================
// WHATSAPP MESSAGE TEMPLATES
// ============================================

model WhatsAppTemplate {
  id         String  @id @default(cuid())
  name       String
  category   String // ONBOARDING, PAYMENT, REMINDER, MARKETING, SUPPORT, NOTIFICATION, CUSTOM
  department String? // SALES, OPERATIONS, HR, ACCOUNTS, ALL
  content    String // Template with {{variable}} placeholders
  variables  String? // JSON array: ["clientName", "amount", "dueDate"]
  language   String  @default("en")

  // Media attachments
  hasMedia  Boolean @default(false)
  mediaType String? // IMAGE, FILE, VIDEO
  mediaUrl  String?

  // Usage tracking
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  // Status
  isActive   Boolean   @default(true)
  isApproved Boolean   @default(false)
  approvedBy String?
  approvedAt DateTime?

  // Audit
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  usageLogs WhatsAppTemplateUsage[]

  @@index([category])
  @@index([department])
  @@index([isActive])
}

model WhatsAppTemplateUsage {
  id         String           @id @default(cuid())
  templateId String
  template   WhatsAppTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  userId         String
  recipientPhone String
  recipientName  String?
  recipientType  String? // CLIENT, LEAD, EMPLOYEE

  // Delivery status
  status    String  @default("SENT") // SENT, DELIVERED, READ, FAILED
  messageId String? // WBizTool message ID
  error     String?

  sentAt      DateTime  @default(now())
  deliveredAt DateTime?
  readAt      DateTime?

  @@index([templateId])
  @@index([userId])
  @@index([sentAt])
}

// Bulk WhatsApp Campaign
model WhatsAppCampaign {
  id          String  @id @default(cuid())
  name        String
  description String?
  templateId  String

  // Target audience
  targetType     String // ALL_CLIENTS, SELECTED_CLIENTS, CLIENT_SEGMENT, LEADS, EMPLOYEES
  targetFilter   String? // JSON filter criteria
  recipientCount Int     @default(0)

  // Scheduling
  status      String    @default("DRAFT") // DRAFT, SCHEDULED, RUNNING, COMPLETED, PAUSED, CANCELLED
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  // Results
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  failedCount    Int @default(0)

  // Audit
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages WhatsAppCampaignMessage[]

  @@index([status])
  @@index([scheduledAt])
}

model WhatsAppCampaignMessage {
  id         String           @id @default(cuid())
  campaignId String
  campaign   WhatsAppCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  recipientPhone String
  recipientName  String?

  status    String  @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  messageId String?
  error     String?

  sentAt      DateTime?
  deliveredAt DateTime?

  @@index([campaignId])
  @@index([status])
}

// ============================================
// DEVICE REQUEST & ALLOCATION
// ============================================

model DeviceRequest {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceType       String // LAPTOP, DESKTOP, MONITOR, KEYBOARD, MOUSE, HEADSET, WEBCAM, PHONE, CHARGER, OTHER
  reason           String // NEW_JOINER, UPGRADE, REPLACEMENT, ADDITIONAL, WFH, PROJECT
  urgency          String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED, ASSIGNED, RETURNED
  approvedBy       String?
  fulfilledAssetId String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// HR PIPELINE TASKS (for Gantt)
// ============================================

model HRPipelineTask {
  id           String    @id @default(cuid())
  userId       String // HR user
  candidateId  String?
  employeeId   String?
  taskType     String // SCREENING, INTERVIEW, ONBOARDING, TRAINING, APPRAISAL
  title        String
  description  String?
  startDate    DateTime
  endDate      DateTime?
  duration     Int? // Days
  progress     Int       @default(0)
  dependencies String? // JSON array of task IDs
  status       String    @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, BLOCKED
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ============================================
// CLIENT OPERATIONS LOG
// ============================================

model ClientOperationsLog {
  id             String    @id @default(cuid())
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date           DateTime  @default(now())
  npsScore       Int?
  flagStatus     String // RED, YELLOW, GREEN
  paymentStatus  String // ON_TIME, OVERDUE, PENDING
  paymentDueDate DateTime?
  remarks        String?
  loggedBy       String
  createdAt      DateTime  @default(now())
}

// ============================================
// WHATSAPP COMMUNICATION SYSTEM (MASH)
// ============================================

// Department WhatsApp account configuration
model WhatsAppAccount {
  id                 String                 @id @default(cuid())
  department         String                 @unique // MANAGER, ACCOUNTS, SALES, HR
  phoneNumber        String                 @unique
  displayName        String
  wbiztoolClientId   Int? // WBizTool client ID
  wbiztoolWhatsappId Int? // WBizTool whatsapp_client ID
  sessionStatus      String                 @default("CONNECTED") // CONNECTED, DISCONNECTED
  isActive           Boolean                @default(true)
  createdById        String
  messages           WhatsAppMessage[]
  schedules          WhatsAppSchedule[]
  accessGrants       WhatsAppAccess[]
  employeeChats      EmployeeWhatsAppChat[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([department])
}

// WhatsApp messages (sent and received)
model WhatsAppMessage {
  id            String            @id @default(cuid())
  accountId     String
  account       WhatsAppAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  direction     String // INBOUND, OUTBOUND
  phoneNumber   String
  contactName   String?
  messageType   String            @default("TEXT") // TEXT, IMAGE, DOCUMENT
  content       String
  mediaUrl      String?
  status        String            @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED
  externalMsgId String?
  clientId      String?
  client        Client?           @relation(fields: [clientId], references: [id])
  sentById      String?
  scheduleId    String?
  schedule      WhatsAppSchedule? @relation(fields: [scheduleId], references: [id])
  sentAt        DateTime?
  createdAt     DateTime          @default(now())

  @@index([accountId, createdAt])
  @@index([phoneNumber])
  @@index([clientId])
  @@index([accountId, phoneNumber]) // PERFORMANCE FIX: Composite index for conversation queries
}

// Scheduled/automated messages
model WhatsAppSchedule {
  id              String            @id @default(cuid())
  accountId       String
  account         WhatsAppAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name            String
  targetType      String // PHONE, CLIENT, CHAT
  targetPhone     String?
  targetClientId  String?
  targetChatId    String? // WhatsApp group/chat ID for direct targeting
  isGroup         Boolean           @default(false)
  messageTemplate String
  scheduleType    String // ONE_TIME, RECURRING
  frequency       String? // DAILY, WEEKLY, MONTHLY
  dayOfWeek       Int? // 0-6 for weekly
  dayOfMonth      Int? // 1-31 for monthly
  scheduledTime   String // HH:MM format
  scheduledAt     DateTime?
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  runCount        Int               @default(0)
  status          String            @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  createdById     String
  messages        WhatsAppMessage[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([accountId, status])
  @@index([nextRunAt])
  @@index([targetChatId])
}

// Department WhatsApp access permissions
model WhatsAppAccess {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  account     WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accessLevel String          @default("VIEW") // VIEW, SEND, ADMIN
  grantedById String
  grantedAt   DateTime        @default(now())

  @@unique([userId, accountId])
}

// Employee-specific WhatsApp chat assignments
// Allows assigning specific chats to specific employees
model EmployeeWhatsAppChat {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String
  account      WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  phoneNumber  String // Chat identifier (contact's phone)
  chatName     String? // Display name for the chat
  assignedAt   DateTime        @default(now())
  assignedById String? // Who assigned this chat

  @@unique([userId, accountId, phoneNumber])
  @@index([userId])
  @@index([accountId])
  @@index([phoneNumber])
}

// WhatsApp session persistence (for Baileys)
model WhatsAppSession {
  id              String    @id @default(cuid())
  sessionId       String    @unique // Format: {department} (e.g., "ACCOUNTS", "SALES")
  department      String
  userId          String
  status          String    @default("disconnected") // initializing, qr, authenticated, ready, disconnected, error
  phoneNumber     String?
  lastError       String?
  reconnectCount  Int       @default(0)
  lastConnectedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([department])
  @@index([userId])
  @@index([status])
}

// Baileys auth state storage (replaces filesystem .whatsapp-auth)
model WhatsAppAuthState {
  id        String   @id @default(cuid())
  sessionId String // e.g., "ACCOUNTS", "SALES"
  key       String // e.g., "creds", "app-state-sync-key-xxx", "sender-key-xxx"
  value     String // JSON serialized (large text for auth keys)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, key])
  @@index([sessionId])
}

// User pinned chats for quick access
model UserPinnedChat {
  id             String   @id @default(cuid())
  userId         String
  chatIdentifier String // Phone number or group ID
  chatName       String
  isGroup        Boolean  @default(false)
  pinnedAt       DateTime @default(now())

  @@unique([userId, chatIdentifier])
  @@index([userId])
}

// ============================================
// ACCOUNTS DEPARTMENT - BANK STATEMENTS
// ============================================

model BankStatement {
  id             String   @id @default(cuid())
  entityId       String // ATZ_MEDAPPZ or BRANDING_PIONEERS
  bankName       String // HDFC, AXIS, KOTAK, ICICI
  accountType    String // SAVINGS, CURRENT, CREDIT_CARD
  accountNumber  String? // Last 4 digits for reference
  statementMonth DateTime // Month/year of the statement
  fileName       String
  fileUrl        String?
  status         String   @default("UPLOADED") // UPLOADED, PROCESSING, PROCESSED, FAILED

  // Balances
  openingBalance Float?
  closingBalance Float?
  totalCredits   Float?
  totalDebits    Float?

  // Matching stats
  matchedCount   Int @default(0)
  unmatchedCount Int @default(0)

  // AI Processing
  aiParsingResult String? // JSON: parsing metadata, confidence scores
  processingError String? // Error message if failed
  processedAt     DateTime?

  // Relations
  transactions BankTransaction[]

  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityId, statementMonth])
  @@index([bankName])
  @@index([status])
}

model BankTransaction {
  id          String        @id @default(cuid())
  statementId String
  statement   BankStatement @relation(fields: [statementId], references: [id], onDelete: Restrict)

  // Transaction details
  transactionDate DateTime
  valueDate       DateTime?
  description     String
  reference       String? // UTR, cheque number, etc.
  type            String // CREDIT, DEBIT
  amount          Float
  balance         Float? // Running balance

  // Matching
  matchStatus     String             @default("UNMATCHED") // UNMATCHED, AUTO_MATCHED, MANUAL_MATCHED, IGNORED
  matchConfidence Float? // AI confidence score (0-1)
  clientId        String?
  client          Client?            @relation(fields: [clientId], references: [id])
  invoiceId       String?
  invoice         Invoice?           @relation(fields: [invoiceId], references: [id])
  paymentId       String?
  payment         PaymentCollection? @relation(fields: [paymentId], references: [id])

  // Categorization
  category    String? // INCOME, EXPENSE, TRANSFER, SALARY, VENDOR, GST, TDS
  subcategory String? // More specific category
  expenseId   String? // Link to Expense if applicable

  // AI Processing
  aiParsedData String? // JSON: extracted data, suggested matches

  // Review
  isReviewed  Boolean   @default(false)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statementId])
  @@index([transactionDate])
  @@index([matchStatus])
  @@index([clientId])
  @@index([category])
}

// ============================================
// ACCOUNTS DEPARTMENT - ROI & EXPENSES
// ============================================

model DepartmentExpense {
  id         String   @id @default(cuid())
  department String // SEO, SOCIAL, ADS, WEB, AI_TOOLS
  month      DateTime // First day of month

  // Salary Components (aggregated - NO individual visibility)
  baseSalaryComponent  Float @default(0) // Total base salaries for dept
  rbcComponent         Float @default(0) // Total RBC allocations for dept
  totalSalaryComponent Float @default(0) // Base + RBC

  // Other Expenses
  toolsExpense      Float @default(0) // Software, subscriptions
  freelancerExpense Float @default(0) // Outsourced work
  miscExpense       Float @default(0) // Other departmental expenses
  totalExpense      Float @default(0) // Sum of all expenses

  // Revenue Attribution
  attributedRevenue Float @default(0) // Revenue from clients using this dept's services
  clientCount       Int   @default(0) // Number of clients served

  // Calculated Metrics
  roi              Float? // (Revenue - Expense) / Expense * 100
  costPerClient    Float? // Expense / clientCount
  revenuePerClient Float? // Revenue / clientCount

  notes        String?
  calculatedAt DateTime?
  calculatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([department, month])
  @@index([month])
}

model DepartmentSalaryAllocation {
