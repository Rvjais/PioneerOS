// ============================================
// GROWTH SCORE & TACTICAL TRACKING
// ============================================

// Social Media Post tracking for tactical meetings
model SocialMediaPost {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month    DateTime // Month this post belongs to

  // Post details
  postUrl     String // URL to the post
  platform    String // INSTAGRAM, FACEBOOK, LINKEDIN, TWITTER, YOUTUBE
  contentType String // POST, REEL, STORY, CAROUSEL, VIDEO, SHORT
  caption     String?
  postedAt    DateTime

  // Engagement metrics
  likes          Int   @default(0)
  comments       Int   @default(0)
  shares         Int   @default(0)
  saves          Int   @default(0)
  reach          Int   @default(0)
  impressions    Int   @default(0)
  views          Int? // For videos/reels
  watchTime      Int? // Total watch time in seconds
  engagementRate Float @default(0)

  // Content performance
  isTopPerformer   Boolean @default(false)
  performanceNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, month])
  @@index([clientId, month])
  @@index([platform])
}

// Monthly Growth Score - comprehensive performance scoring
model MonthlyGrowthScore {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month  DateTime

  // Component Scores (all out of 100)
  // Performance Score - KPI growth from tactical data
  performanceScore     Float   @default(0)
  performanceBreakdown String? // JSON: { kpiName: score, ... }

  // Accountability Score - clients managed vs capacity
  accountabilityScore Float   @default(0)
  clientsManaged      Int     @default(0)
  clientCapacity      Int     @default(10) // How many clients they're paid to manage
  accountabilityNotes String?

  // Discipline Score - attendance from Razorpay/MyZen
  disciplineScore  Float   @default(0)
  presentDays      Int     @default(0)
  lateDays         Int     @default(0)
  absentDays       Int     @default(0)
  onTimePercentage Float   @default(0)
  disciplineSource String? // RAZORPAY, MYZEN, MANUAL

  // Learning Score - from learning hours
  learningScore         Float @default(0)
  learningHoursLogged   Float @default(0)
  learningHoursRequired Float @default(6)

  // Appreciation Score - from recognition/testimonials
  appreciationScore    Float @default(0)
  managerAppreciations Int   @default(0)
  clientAppreciations  Int   @default(0)
  testimonials         Int   @default(0)

  // Penalty Deductions
  escalationsCount    Int   @default(0)
  escalationDeduction Float @default(0)
  clientsLost         Int   @default(0)
  churnDeduction      Float @default(0)

  // Final Score Calculation
  // Formula: (Performance * 0.35) + (Accountability * 0.20) + (Discipline * 0.15) +
  //          (Learning * 0.15) + (Appreciation * 0.15) - Deductions
  finalScore Float   @default(0)
  scoreGrade String? // A+, A, B+, B, C, D, F

  // Data submission tracking
  tacticalDataSubmitted Boolean   @default(false)
  submittedAt           DateTime?
  submittedOnTime       Boolean   @default(false) // Before 5th of month

  // Review
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
  @@index([month])
  @@index([finalScore])
}

// Social Media Page Metrics - monthly overview per client
model SocialMediaPageMetrics {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month    DateTime
  platform String // INSTAGRAM, FACEBOOK, LINKEDIN, TWITTER, YOUTUBE

  // Follower/Subscriber metrics
  followers      Int   @default(0)
  prevFollowers  Int   @default(0)
  followerGrowth Float @default(0)

  // Reach/Impressions
  totalReach     Int   @default(0)
  prevTotalReach Int   @default(0)
  reachGrowth    Float @default(0)

  // Engagement
  totalEngagement    Int   @default(0)
  engagementRate     Float @default(0)
  prevEngagementRate Float @default(0)

  // Content published
  postsPublished   Int @default(0)
  reelsPublished   Int @default(0)
  storiesPublished Int @default(0)

  // Lead generation
  leadsGenerated Int @default(0)
  linkClicks     Int @default(0)
  profileVisits  Int @default(0)

  // Platform-specific
  connections Int? // LinkedIn
  subscribers Int? // YouTube
  videoViews  Int? // YouTube/Reels total

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, month, platform])
  @@index([userId, month])
  @@index([clientId])
}

// Recurring Expense - for Accounts team to track recurring costs
model RecurringExpense {
  id          String  @id @default(cuid())
  name        String // Expense name (e.g., "AWS Hosting", "Adobe Subscription")
  description String?

  // Categorization
  category String // SUBSCRIPTION, TOOL, HOSTING, SALARY, VENDOR, RENT, UTILITIES, MARKETING, OTHER
  vendor   String? // Vendor/Provider name

  // Recurring settings
  frequency String // DAILY, WEEKLY, MONTHLY, QUARTERLY, HALF_YEARLY, YEARLY
  amount    Float // Base amount per occurrence
  currency  String @default("INR")

  // Schedule
  startDate    DateTime
  endDate      DateTime? // null = ongoing
  nextDueDate  DateTime
  lastPaidDate DateTime?

  // Client/Project allocation (optional)
  isClientBillable Boolean @default(false)

  // Auto-payment settings
  autoPayEnabled Boolean @default(false)
  reminderDays   Int     @default(3) // Days before due date to remind

  // Status
  status String @default("ACTIVE") // ACTIVE, PAUSED, CANCELLED, COMPLETED

  // Tracking
  createdBy String
  creator   User   @relation("ExpenseCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  // Relations
  allocations ExpenseAllocation[]
  payments    ExpensePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([nextDueDate])
  @@index([createdBy])
}

// Expense Allocation - link expense to clients/projects for cost attribution
model ExpenseAllocation {
  id        String           @id @default(cuid())
  expenseId String
  expense   RecurringExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Allocation percentage (for shared expenses)
  percentage  Float  @default(100) // 0-100
  fixedAmount Float? // If fixed amount instead of percentage

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expenseId])
  @@index([clientId])
}

// Expense Payment - track individual payments for recurring expenses
model ExpensePayment {
  id        String           @id @default(cuid())
  expenseId String
  expense   RecurringExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  amount   Float
  paidDate DateTime
  dueDate  DateTime

  paymentMethod  String? // BANK_TRANSFER, UPI, CREDIT_CARD, CASH, CHEQUE
  transactionRef String? // Bank transaction reference
  receipt        String? // Receipt/invoice file URL

  status String  @default("PAID") // PAID, PENDING, FAILED, REFUNDED
  notes  String?

  paidBy String?
  payer  User?   @relation(fields: [paidBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expenseId])
  @@index([paidDate])
  @@index([status])
}

// Goal - Paperclip-style hierarchical goals for alignment
model Goal {
  id String @id @default(cuid())

  // Goal hierarchy
  level    String // MISSION, STRATEGIC, DEPARTMENTAL, TEAM, INDIVIDUAL, TASK
  parentId String?
  parent   Goal?   @relation("GoalHierarchy", fields: [parentId], references: [id])
  children Goal[]  @relation("GoalHierarchy")

  // Goal details
  title       String
  description String?

  // Quarterly goal category
  category String? // CLIENT, LEARNING, SKILL, SALES, CLIENT_SATISFACTION, PROCESS, RECRUITMENT, COMPLIANCE, REPORTING, TEAM_BUILDING
  quarter  Int? // 1, 2, 3, 4
  year     Int? // e.g., 2026

  // Client-specific goals
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Ownership
  department String? // Which department owns this goal
  ownerId    String?
  owner      User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  // Timeline
  startDate     DateTime?
  targetDate    DateTime?
  completedDate DateTime?

  // Metrics
  targetValue  Float? // Numeric target (e.g., 100 new clients)
  currentValue Float   @default(0)
  unit         String? // clients, revenue, %, hours, etc.

  // Status
  status   String @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, AT_RISK, COMPLETED, CANCELLED
  progress Float  @default(0) // 0-100%

  // Scoring
  weight Float  @default(1) // Relative importance
  score  Float? // Actual achievement score

  // End-of-quarter review
  achievementNotes String? // What was achieved/not achieved
  selfRating       Int? // 1-5 self-assessment

  // Audit
  createdBy String
  creator   User   @relation("GoalCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  // Relations
  taskLinks TaskGoalLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@index([parentId])
  @@index([department])
  @@index([ownerId])
  @@index([status])
  @@index([category])
  @@index([quarter, year])
  @@index([clientId])
}

// Task-Goal Link - connect tasks to goals for traceability
model TaskGoalLink {
  id String @id @default(cuid())

  goalId String
  goal   Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  // Link to various task types
  dailyTaskId String?
  dailyTask   DailyTask? @relation(fields: [dailyTaskId], references: [id], onDelete: Cascade)

  workEntryId String?
  workEntry   WorkEntry? @relation(fields: [workEntryId], references: [id], onDelete: Cascade)

  // Contribution weight
  contributionWeight Float @default(1) // How much this task contributes to goal

  notes String?

  createdAt DateTime @default(now())

  @@index([goalId])
  @@index([dailyTaskId])
  @@index([workEntryId])
}

// Budget Alert - Paperclip-style budget monitoring with thresholds
model BudgetAlert {
  id String @id @default(cuid())

  // Scope
  scope      String // CLIENT, PROJECT, DEPARTMENT, COMPANY
  clientId   String?
  client     Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  department String?

  // Budget limits
  budgetAmount Float // Total budget
  currency     String    @default("INR")
  period       String // MONTHLY, QUARTERLY, YEARLY, PROJECT
  periodStart  DateTime
  periodEnd    DateTime?

  // Thresholds
  warningThreshold  Float @default(80) // % at which to warn (yellow)
  criticalThreshold Float @default(100) // % at which to pause/alert (red)

  // Current tracking
  spentAmount     Float @default(0)
  spentPercentage Float @default(0)

  // Alert state
  alertLevel    String    @default("NORMAL") // NORMAL, WARNING, CRITICAL, EXCEEDED
  lastAlertSent DateTime?
  alertsEnabled Boolean   @default(true)

  // Auto-actions (Paperclip feature)
  pauseOnCritical Boolean   @default(false) // Auto-pause spending at critical
  isPaused        Boolean   @default(false)
  pausedAt        DateTime?
  pausedBy        String?

  // Notifications
  notifyUsers      String? // JSON array of user IDs to notify
  notifyOnWarning  Boolean @default(true)
  notifyOnCritical Boolean @default(true)

  // Audit
  createdBy String
  creator   User   @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope])
  @@index([clientId])
  @@index([department])
  @@index([alertLevel])
  @@index([periodStart, periodEnd])
}

// ============================================
// PLATFORM INTEGRATIONS (Google, Meta, LinkedIn)
// ============================================

// OAuth connections for each client's platforms
model ClientOAuthConnection {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  platform     String // GOOGLE, META, LINKEDIN, TWITTER
  accessToken  String // Encrypted
  refreshToken String? // Encrypted
  tokenType    String    @default("Bearer")
  expiresAt    DateTime?
  scopes       String? // JSON array of granted scopes

  // Connection status
  status         String    @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED, ERROR
  lastError      String?
  lastSyncAt     DateTime?
  lastSyncStatus String? // SUCCESS, FAILED, PARTIAL

  // Who connected
  connectedBy String?
  connectedAt DateTime @default(now())

  // Platform-specific data
  platformUserId String? // User ID on the platform
  platformEmail  String? // Email on the platform

  // Agency access (for Super Admin management)
  agencyAccessGranted    Boolean   @default(false)
  agencyAccessVerifiedAt DateTime?
  delegatedToEmail       String?

  // Related accounts
  accounts PlatformAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, platform])
  @@index([clientId])
  @@index([platform])
  @@index([status])
}

// Individual accounts/properties within a platform connection
model PlatformAccount {
  id           String                @id @default(cuid())
  connectionId String
  connection   ClientOAuthConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  // Account identification
  platform    String // GOOGLE_ANALYTICS, GOOGLE_SEARCH_CONSOLE, GOOGLE_ADS, META_PAGE, META_AD_ACCOUNT, LINKEDIN_PAGE
  accountId   String // Platform's account ID
  accountName String // Display name
  accountType String? // PAGE, PROPERTY, AD_ACCOUNT, etc.

  // Platform-specific metadata
  metadata String? // JSON - platform-specific data (property ID, page category, etc.)

  // Status
  isActive       Boolean   @default(true)
  isPrimary      Boolean   @default(false) // Primary account for this platform type
  lastSyncAt     DateTime?
  lastSyncStatus String?

  // Metrics
  metrics PlatformMetric[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([connectionId, platform, accountId])
  @@index([connectionId])
  @@index([platform])
  @@index([isActive])
}

// Daily metrics pulled from platforms
model PlatformMetric {
  id        String          @id @default(cuid())
  accountId String
  account   PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Time period
  date       DateTime // Date of the metric
  periodType String   @default("DAILY") // DAILY, WEEKLY, MONTHLY

  // Metric type and value
  metricType  String // FOLLOWERS, IMPRESSIONS, CLICKS, SESSIONS, CONVERSIONS, SPEND, etc.
  metricValue Float
  metricUnit  String? // COUNT, CURRENCY, PERCENTAGE, SECONDS

  // Comparison
  previousValue Float? // Previous period value for comparison
  changePercent Float? // % change from previous

  // Breakdown dimensions (optional)
  dimension      String? // e.g., "country", "device", "keyword"
  dimensionValue String? // e.g., "India", "mobile", "digital marketing"

  // Raw data
  rawData String? // JSON - full API response for debugging

  createdAt DateTime @default(now())

  @@unique([accountId, date, metricType, dimension, dimensionValue])
  @@index([accountId])
  @@index([date])
  @@index([metricType])
  @@index([accountId, date])
}

// Sync job tracking
model PlatformSyncJob {
  id           String  @id @default(cuid())
  connectionId String?
  accountId    String?

  // Job details
  platform String
  syncType String // FULL, INCREMENTAL, ACCOUNTS_DISCOVERY
  status   String @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED

  // Time tracking
  startedAt   DateTime?
  completedAt DateTime?

  // Results
  recordsProcessed Int     @default(0)
  recordsFailed    Int     @default(0)
  errorMessage     String?
  errorDetails     String? // JSON

  createdAt DateTime @default(now())

  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// MAGIC LINK AUTHENTICATION
// ============================================

model MagicLinkToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String    @default("EMAIL") // EMAIL or WHATSAPP
