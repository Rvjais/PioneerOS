// Monthly accountability score per employee
model AccountabilityScore {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month  DateTime // Month/Year for this score

  // Work Metrics (proportional to salary)
  expectedUnits  Int // Based on salary & department baseline
  deliveredUnits Int   @default(0)
  unitScore      Float @default(0) // (delivered/expected) * 100

  // Growth Metrics (from tactical meetings)
  tacticalGoals String? // JSON array of goals
  goalsAchieved Int     @default(0)
  totalGoals    Int     @default(0)
  growthScore   Float   @default(0) // (achieved/total) * 100

  // Final Aggregated Score
  finalScore  Float @default(0) // Weighted average
  rank        Int? // Monthly rank within department
  companyRank Int? // Company-wide rank

  // Manager's subjective rating (1-10)
  managerRating Float? // 1-10 personality & performance score
  managerNotes  String? // Manager's written feedback

  // Metadata
  calculatedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, month])
}

model LearningLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month          DateTime // Month this learning applies to
  resourceUrl    String // YouTube/Udemy/etc link
  resourceTitle  String
  topic          String? // Topic/category of learning (e.g., SEO, Marketing, etc.)
  minutesWatched Int // Duration in minutes
  notes          String?
  createdAt      DateTime @default(now())

  // AI Verification fields
  verificationId String? // Link to verification task
  verification   LearningVerification? @relation(fields: [verificationId], references: [id])

  @@index([userId])
}

// AI-powered learning verification
model LearningVerification {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningLogId String? // Optional link back to specific log
  topic         String // Topic being verified
  resourceTitle String // What was learned

  // AI-generated practical task
  taskPrompt String // The practical task/question generated by AI
  taskType   String @default("PRACTICAL") // PRACTICAL, REFLECTION, QUIZ
  difficulty String @default("MEDIUM") // EASY, MEDIUM, HARD

  // User response
  userResponse String? // User's answer/submission
  submittedAt  DateTime?

  // AI evaluation
  aiScore     Float? // Score 0-100
  aiFeedback  String? // AI's feedback on the response
  evaluatedAt DateTime?
  isVerified  Boolean   @default(false)

  status    String   @default("PENDING") // PENDING, SUBMITTED, EVALUATED, SKIPPED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  learningLogs LearningLog[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Monthly learning audit summary
model LearningAudit {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month  DateTime // Month being audited

  // Stats
  totalEntries    Int    @default(0)
  totalMinutes    Int    @default(0)
  verifiedEntries Int    @default(0)
  averageScore    Float? // Average verification score

  // AI audit summary
  aiSummary         String? // AI-generated summary of what was learned
  aiRecommendations String? // AI suggestions for improvement
  overallVerdict    String? // EXCELLENT, GOOD, NEEDS_IMPROVEMENT, CONCERNING

  auditedAt DateTime @default(now())

  @@unique([userId, month])
  @@index([userId])
}

// Work deliverables tracking by type
model WorkDeliverable {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  month           DateTime // Month of delivery
  category        String // SOCIAL_MEDIA, SEO, DESIGN, VIDEO, WEB, ADS, ACCOUNT_MANAGEMENT
  deliverableType String // STANDARD_POST, CAROUSEL, REEL, BLOG, PAGE, CAMPAIGN, etc.
  quantity        Int      @default(1)
  unitValue       Float // Value in rupees per unit
  totalValue      Float // quantity * unitValue

  // Proof of delivery
  proofUrl String? // URL to proof file or folder

  // Design/Creative-specific KPIs
  qualityScore    Int? // Rating from 1-10 (assigned by reviewer/manager)
  revisionCount   Int     @default(0) // Number of revisions needed
  turnaroundHours Float? // Hours from assignment to first delivery
  designUrls      String? // JSON array of design URLs for each piece

  // Status
  status     String    @default("COMPLETED") // COMPLETED, APPROVED, REJECTED
  approvedBy String?
  approvedAt DateTime?

  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

// Department baseline expectations (for calculating expected units)
model DepartmentBaseline {
  id         String @id @default(cuid())
  department String @unique

  // Base salary expectations
  baseSalary Float // Reference salary for baseline
  baseUnits  Int // Expected units at base salary

  // Unit definitions
  unitType        String // CLIENTS, CREATIVES, PAGES, CAMPAIGNS, etc.
  unitDescription String?

  // Scaling
  scaleFactor Float @default(1.0) // How units scale with salary

  updatedAt DateTime @updatedAt
}

// Employee achievements (appreciations, sales, testimonials)
model Achievement {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String // CLIENT_APPRECIATION, VIDEO_TESTIMONIAL, GOOGLE_REVIEW, SALE_CLOSED, CLIENT_REFERRAL, EMPLOYEE_REFERRAL, ATTENDANCE_PERFECT
  title       String
  description String?

  // Source/Evidence
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
  proofUrl String? // Screenshot, video link, etc.

  // Value/Points
  pointsAwarded  Int    @default(0)
  incentiveValue Float? // Rupees if monetary

  // Approval
  status     String    @default("PENDING") // PENDING, APPROVED, REJECTED
  addedBy    String // Manager who added this
  approvedBy String?
  approvedAt DateTime?

  // Period
  month     DateTime // Month this counts towards
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

// Tactical/Strategic meeting goals
model TacticalGoal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month        DateTime // Month for this goal
  title        String
  description  String?
  targetValue  Float? // Quantifiable target
  currentValue Float? // Current progress

  category String // GROWTH, QUALITY, EFFICIENCY, CLIENT_SATISFACTION, LEARNING
  priority String @default("MEDIUM") // LOW, MEDIUM, HIGH

  status     String    @default("IN_PROGRESS") // IN_PROGRESS, ACHIEVED, MISSED, CANCELLED
  achievedAt DateTime?

  setBy       String // Manager who set this goal
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Incentive payouts record
model IncentivePayout {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month DateTime

  // Breakdown
  unitIncentive    Float @default(0) // From deliverables
  achievementBonus Float @default(0) // From achievements
  referralBonus    Float @default(0) // From referrals
  attendanceBonus  Float @default(0) // From perfect attendance

