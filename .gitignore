# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# uploads (local dev fallback)
/public/uploads

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
._*
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env
.env.local
.env.development
.env.production
.env.production.local
.env.staging
production.env
.local.env
development.env
staging.env
*.env
!.env.example
!.env.template

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma (generated client)
/src/generated/prisma

# local databases
prisma/*.db
prisma/*.db-journal
prisma/*.db.gz

# test artifacts
/screenshots
/test-screenshots
/test-results
/e2e-tests/screenshots

# whatsapp cache
/.wwebjs_cache

# pioneer data (local storage)
/pioneer_data
/uploads
/data
logs/
*.log

# supabase
/supabase/.branches
/supabase/.temp

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.cache/

# build outputs
/pioneer-os-standalone
/dist
/.cache
.turbo

# sentry (error tracking)
/sentry*config*

# cron job logs
*.crons
.cron-logs/

# backup files
*.bak
*.backup
*.sql.gz
