# Next.js Static Files MIME Types
<IfModule mod_mime.c>
    AddType application/javascript js jsx
    AddType text/css css
    AddType application/json json
    AddType image/svg+xml svg svgz
    AddType font/woff2 woff2
    AddType font/woff woff
    AddType font/ttf ttf
    AddType font/eot eot
    AddType font/otf otf
    AddType image/png png
    AddType image/jpeg jpg jpeg
    AddType image/gif gif
    AddType image/webp webp
    AddType image/ico ico
    AddType image/bmp bmp
    AddType text/plain txt
    AddType text/xml xml
    AddType application/xml xml
    AddType application/wasm wasm
</IfModule>

# Serve static files from .next directory with proper caching
<IfModule mod_headers.c>
    <LocationMatch "\.next/static/(.*)">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </LocationMatch>
</IfModule>

# Disable LiteSpeed compression for static files to prevent corruption
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/_next/static/ [NC]
    RewriteRule ^ - [E=NO_VARY:1]
</IfModule>
